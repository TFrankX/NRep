<link rel="stylesheet" href="~/jqwidgets/styles/jqx.base.css" type="text/css" />
<link rel="stylesheet" href="~/jqwidgets/styles/jqx.material-purple.css" type="text/css" />
<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
<meta name="viewport" content="width=device-width, initial-scale=1 maximum-scale=1 minimum-scale=1" />

@{
    ViewData["Title"] = "PowerBank Statistics";
}

@section scripts
{
    <script type="text/javascript">
        function cellsrenderer(row, column, value) {
            var jsonmod = source.localdata;
            if (!jsonmod || !jsonmod[row]) return "<div></div>";

            var backcolor = "#FFFFFF";
            var status = jsonmod[row].Status;

            // Color coding by status
            if (status === "On hands") {
                backcolor = "#FEF3C7"; // Yellow - taken, station online
            } else if (status === "Returned") {
                backcolor = "#D1FAE5"; // Green - returned
            } else if (status === "Returned (Offline)" || status === "In station (Offline)") {
                backcolor = "#E5E7EB"; // Gray - in offline station
            } else if (status === "Offline") {
                backcolor = "#FEE2E2"; // Red - taken, station offline
            } else if (status === "In station") {
                backcolor = "#DBEAFE"; // Light blue - in station
            } else {
                backcolor = "#F3F4F6"; // Gray - unknown
            }

            var divstartstyle = "<div style='height: 100%; min-height: 40px; width: 100%; background: " + backcolor + "; display: flex; align-items: center; padding: 0 8px;'>";

            // Status column with badge
            if (column === 'Status') {
                var badgeClass, icon;
                if (status === "On hands") {
                    badgeClass = "badge-warning";
                    icon = "fa-hand-holding";
                } else if (status === "Returned") {
                    badgeClass = "badge-success";
                    icon = "fa-check-circle";
                } else if (status === "Returned (Offline)") {
                    badgeClass = "badge-secondary";
                    icon = "fa-check-circle";
                } else if (status === "In station (Offline)") {
                    badgeClass = "badge-secondary";
                    icon = "fa-charging-station";
                } else if (status === "Offline") {
                    badgeClass = "badge-danger";
                    icon = "fa-wifi";
                } else if (status === "In station") {
                    badgeClass = "badge-info";
                    icon = "fa-charging-station";
                } else {
                    badgeClass = "badge-secondary";
                    icon = "fa-question-circle";
                }
                return divstartstyle +
                    "<span class='status-badge " + badgeClass + "'><i class='fas " + icon + " me-1'></i>" + value + "</span>" +
                    "</div>";
            }

            // PowerBank ID
            if (column === 'PowerBankId') {
                return divstartstyle +
                    "<span style='font-family: monospace; font-size: 0.8rem; color: #6B7280;'>" + value + "</span>" +
                    "</div>";
            }

            // Station name
            if (column === 'StationName') {
                return divstartstyle +
                    "<span class='station-name'><i class='fas fa-charging-station me-1'></i>" + value + "</span>" +
                    "</div>";
            }

            // Slot number
            if (column === 'Slot') {
                return divstartstyle +
                    "<span class='status-circle purple'>" + value + "</span>" +
                    "</div>";
            }

            // User ID
            if (column === 'UserId') {
                if (!value || value === "") {
                    return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
                }
                return divstartstyle +
                    "<span style='font-weight: 500;'><i class='fas fa-user me-1' style='color: #7C3AED;'></i>" + value + "</span>" +
                    "</div>";
            }

            // Take time
            if (column === 'TakeTime') {
                if (!value || value === "0001-01-01T00:00:00") {
                    return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
                }
                var date = new Date(value);
                var formatted = date.toLocaleDateString('ru-RU') + ' ' + date.toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'});
                return divstartstyle +
                    "<span style='font-size: 0.85rem;'><i class='fas fa-sign-out-alt me-1' style='color: #F59E0B;'></i>" + formatted + "</span>" +
                    "</div>";
            }

            // Return time
            if (column === 'ReturnTime') {
                if (!value || value === null) {
                    return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
                }
                var date = new Date(value);
                var formatted = date.toLocaleDateString('ru-RU') + ' ' + date.toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'});
                return divstartstyle +
                    "<span style='font-size: 0.85rem;'><i class='fas fa-sign-in-alt me-1' style='color: #10B981;'></i>" + formatted + "</span>" +
                    "</div>";
            }

            // Duration
            if (column === 'Duration') {
                return divstartstyle +
                    "<span style='font-size: 0.85rem;'><i class='fas fa-clock me-1' style='color: #6B7280;'></i>" + value + "</span>" +
                    "</div>";
            }

            // Cost with reset button
            if (column === 'Cost') {
                var costValue = value ? parseFloat(value).toFixed(2) : '0.00';
                var color = parseFloat(costValue) > 0 ? '#059669' : '#9CA3AF';
                var pbId = jsonmod[row].PowerBankId;
                var hasValue = parseFloat(costValue) > 0;
                return divstartstyle +
                    "<div style='display: flex; align-items: center; gap: 8px;'>" +
                    "<span style='font-weight: 600; color: " + color + ";'>" + costValue + " EUR</span>" +
                    (hasValue ? "<button onclick=\"resetCost('" + pbId + "')\" class='reset-btn' title='Reset cost'><i class='fas fa-undo'></i></button>" : "") +
                    "</div></div>";
            }

            // Total Earnings with reset button
            if (column === 'TotalEarnings') {
                var totalValue = value ? parseFloat(value).toFixed(2) : '0.00';
                var color = parseFloat(totalValue) > 0 ? '#7C3AED' : '#9CA3AF';
                var pbId = jsonmod[row].PowerBankId;
                var hasValue = parseFloat(totalValue) > 0;
                return divstartstyle +
                    "<div style='display: flex; align-items: center; gap: 8px;'>" +
                    "<span style='font-weight: 600; color: " + color + ";'>" + totalValue + " EUR</span>" +
                    (hasValue ? "<button onclick=\"resetTotal('" + pbId + "')\" class='reset-btn' title='Reset total'><i class='fas fa-undo'></i></button>" : "") +
                    "</div></div>";
            }

            // Session status
            if (column === 'SessionId') {
                if (value === "Active") {
                    return divstartstyle +
                        "<span class='status-badge badge-info'><i class='fas fa-credit-card me-1'></i>Payment active</span>" +
                        "</div>";
                }
                return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
            }

            // Charge level
            if (column === 'ChargeLevel') {
                var enumValue = value || 0;
                var level = enumValue === 1 ? 10 : enumValue === 2 ? 30 : enumValue === 3 ? 50 : enumValue === 4 ? 70 : enumValue >= 5 ? 100 : 0;
                var color = level > 60 ? '#22C55E' : (level > 30 ? '#F59E0B' : '#EF4444');
                return divstartstyle +
                    "<div style='display: flex; align-items: center; gap: 6px;'>" +
                    "<i class='fas fa-battery-" + (level > 75 ? "full" : level > 50 ? "three-quarters" : level > 25 ? "half" : "quarter") + "' style='color: " + color + ";'></i>" +
                    "<span style='font-size: 0.8rem; color: " + color + ";'>" + level + "%</span>" +
                    "</div></div>";
            }

            // Default
            return divstartstyle +
                "<span style='font-size: 0.85rem;'>" + (value || '-') + "</span>" +
                "</div>";
        }

        function refresh() {
            // Показываем индикатор загрузки только при первой загрузке
            if (!newdata) {
                $('#loadingIndicator').show();
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("RefreshStatistics", "PowerBanks")',
                contentType: 'application/json',
                data: JSON.stringify({}),
                success: function(response) {
                    // Данные приходят в формате { items: [...], currentRevenue: X, totalRevenue: Y }
                    var data = response.items || response;
                    source.localdata = data;
                    if (!newdata) {
                        $("#jqxgrid").jqxGrid({ source: source });
                        newdata = true;
                        $('#loadingIndicator').hide();
                    }
                    $("#jqxgrid").jqxGrid('updatebounddata', 'sort');
                    updateSummary(data, response.currentRevenue, response.totalRevenue);
                },
                error: function() {
                    $('#loadingIndicator').hide();
                }
            });
        }

        function updateSummary(data, currentRevenue, totalRevenue) {
            var onHands = data.filter(x => x.Status === "On hands").length;
            var offline = data.filter(x => x.Status === "Offline").length;
            var returned = data.filter(x => x.Status === "Returned").length;

            $('#summaryOnHands').text(onHands);
            $('#summaryOffline').text(offline);
            $('#summaryReturned').text(returned);
            $('#summaryTotal').text(data.length);
            $('#summaryCurrentRevenue').text((currentRevenue || 0).toFixed(2) + ' EUR');
            $('#summaryTotalRevenue').text((totalRevenue || 0).toFixed(2) + ' EUR');
        }

        var newdata = false;
        var grid = $("#jqxgrid"),
            intervalId = setInterval(refresh, 5000);

        var source = {
            datatype: "json",
            datafields: [
                { name: 'PowerBankId', type: 'string' },
                { name: 'StationName', type: 'string' },
                { name: 'Slot', type: 'number' },
                { name: 'UserId', type: 'string' },
                { name: 'Status', type: 'string' },
                { name: 'TakeTime', type: 'date' },
                { name: 'ReturnTime', type: 'date' },
                { name: 'Duration', type: 'string' },
                { name: 'Cost', type: 'float' },
                { name: 'TotalEarnings', type: 'float' },
                { name: 'SessionId', type: 'string' },
                { name: 'ChargeLevel', type: 'number' }
            ]
        };

        function resetCost(powerBankId) {
            if (!confirm('Reset Cost to 0 for this PowerBank?')) {
                return;
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("ResetPowerBankEarnings", "PowerBanks")',
                contentType: 'application/json',
                data: JSON.stringify({ PowerBankId: powerBankId, ResetCost: true, ResetTotal: false }),
                success: function(response) {
                    if (response.success) {
                        refresh();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('Failed to reset cost');
                }
            });
        }

        function resetTotal(powerBankId) {
            if (!confirm('Reset Total Earnings to 0 for this PowerBank?')) {
                return;
            }
            $.ajax({
                type: "POST",
                url: '@Url.Action("ResetPowerBankEarnings", "PowerBanks")',
                contentType: 'application/json',
                data: JSON.stringify({ PowerBankId: powerBankId, ResetCost: false, ResetTotal: true }),
                success: function(response) {
                    if (response.success) {
                        refresh();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('Failed to reset total');
                }
            });
        }

        var dataAdapter = new $.jqx.dataAdapter(source);

        $(document).ready(function() {
            $("#jqxgrid").jqxGrid({
                width: '100%',
                source: dataAdapter,
                theme: 'material-purple',
                sortable: true,
                filterable: true,
                rowsheight: 48,
                enablebrowserselection: true,
                selectionmode: 'multiplecellsadvanced',
                height: 720,
                columnsresize: true,
                columns: [
                    { text: "Status", datafield: "Status", width: "8%", cellsrenderer: cellsrenderer },
                    { text: "User", datafield: "UserId", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Station", datafield: "StationName", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Slot", datafield: "Slot", width: "4%", cellsrenderer: cellsrenderer },
                    { text: "PowerBank ID", datafield: "PowerBankId", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Take Time", datafield: "TakeTime", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Return Time", datafield: "ReturnTime", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Duration", datafield: "Duration", width: "6%", cellsrenderer: cellsrenderer },
                    { text: "Cost", datafield: "Cost", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Total", datafield: "TotalEarnings", width: "10%", cellsrenderer: cellsrenderer },
                    { text: "Payment", datafield: "SessionId", width: "8%", cellsrenderer: cellsrenderer }
                ]
            });
            refresh();
            // Sort by TakeTime descending (newest first)
            $("#jqxgrid").jqxGrid('sortby', 'TakeTime', 'desc');
        });
    </script>
}

<style>
    .reset-btn {
        padding: 4px 8px;
        border: none;
        background: #FEE2E2;
        color: #DC2626;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.7rem;
        transition: all 0.2s;
    }

    .reset-btn:hover {
        background: #DC2626;
        color: white;
    }

    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 24px;
    }

    .summary-card {
        background: white;
        border-radius: 16px;
        padding: 20px 24px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .summary-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .summary-icon.warning {
        background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
        color: #D97706;
    }

    .summary-icon.success {
        background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
        color: #059669;
    }

    .summary-icon.primary {
        background: linear-gradient(135deg, #EDE9FE 0%, #DDD6FE 100%);
        color: #7C3AED;
    }

    .summary-icon.info {
        background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
        color: #2563EB;
    }

    .summary-icon.danger {
        background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
        color: #DC2626;
    }

    .summary-content h3 {
        font-size: 0.85rem;
        color: #6B7280;
        margin: 0 0 4px 0;
        font-weight: 500;
    }

    .summary-content .value {
        font-size: 1.75rem;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
    }

    .badge-warning {
        background: #FEF3C7;
        color: #D97706;
    }

    .badge-success {
        background: #D1FAE5;
        color: #059669;
    }

    .badge-secondary {
        background: #F3F4F6;
        color: #6B7280;
    }

    .badge-info {
        background: #DBEAFE;
        color: #2563EB;
    }

    .badge-danger {
        background: #FEE2E2;
        color: #DC2626;
    }

    .station-name {
        font-weight: 500;
        color: #7C3AED;
    }

    #loadingIndicator {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(255, 255, 255, 0.95);
        padding: 30px 50px;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        z-index: 1000;
        display: none;
    }

    #loadingIndicator i {
        color: #7C3AED;
        font-size: 2rem;
    }
</style>

<div class="page-header">
    <h1><i class="fas fa-chart-bar"></i> PowerBank Statistics</h1>
    <p class="page-subtitle">Track powerbank rentals and returns</p>
</div>

<div class="summary-cards">
    <div class="summary-card">
        <div class="summary-icon warning">
            <i class="fas fa-hand-holding"></i>
        </div>
        <div class="summary-content">
            <h3>On Hands</h3>
            <p class="value" id="summaryOnHands">0</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon danger">
            <i class="fas fa-wifi"></i>
        </div>
        <div class="summary-content">
            <h3>Offline</h3>
            <p class="value" id="summaryOffline">0</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon success">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="summary-content">
            <h3>Returned</h3>
            <p class="value" id="summaryReturned">0</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon info">
            <i class="fas fa-clock"></i>
        </div>
        <div class="summary-content">
            <h3>Current Revenue</h3>
            <p class="value" id="summaryCurrentRevenue">0.00 EUR</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon primary">
            <i class="fas fa-euro-sign"></i>
        </div>
        <div class="summary-content">
            <h3>Total Revenue</h3>
            <p class="value" id="summaryTotalRevenue">0.00 EUR</p>
        </div>
    </div>
</div>

<div class="grid-container">
    <div id="jqxgrid"></div>
</div>

<div id="loadingIndicator">
    <i class="fas fa-spinner fa-spin"></i>
    <span style="margin-left: 12px; font-weight: 500;">Loading...</span>
</div>
