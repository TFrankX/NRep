        function GoToDetails(deviceName) {
            if (deviceName == null)
                return;

            // Find device ID by name
            var device = source.localdata.find(d => d.DeviceName === deviceName);
            if (device) {
                window.location.href = '@Url.Action("StationActions", "Actions")' +
                    '?stationId=' + device.Id_str +
                    '&stationName=' + encodeURIComponent(deviceName);
                return;
            }

            // Fallback to old behavior if device not found
            $.ajax({
                type: "POST",
                url: '@Url.Action("SetFilter", "Devices")',
                contentType: 'application/json',
                data: JSON.stringify({
                    Filter: deviceName
                }),
                success: function () {
                    //location.href = document.location.origin + '@Url.Action("ServerDetails", "ServerDetails")';
                    location.href = document.location.origin + '@Url.Action("Devices", "Devices")';
                }
            });
        }
