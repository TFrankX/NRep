        var pushInProgress = {};  // Track ongoing push requests

        function PushPB(DeviceName, PBNumber, event) {
            // Prevent double-clicks and clicks during refresh
            var key = DeviceName + '_' + PBNumber;
            if (pushInProgress[key]) {
                console.log('Push already in progress for ' + key);
                return;
            }

            // Stop event propagation to prevent grid refresh interference
            if (event) {
                event.stopPropagation();
                event.preventDefault();
            }

            pushInProgress[key] = true;

            // Find and disable the button
            var btn = event ? event.target.closest('button') : null;
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            }

            $.ajax({
                type: "POST",
                url: '@Url.Action("PushPB", "Devices")',
                contentType: 'application/json',
                data: JSON.stringify({
                    DeviceName: DeviceName,
                    PowerBankNum: PBNumber
                }),
                success: function (response) {
                    console.log('Push success:', response);
                    // Visual feedback - button stays disabled until refresh updates it
                },
                error: function (xhr, status, error) {
                    console.error('Push error:', error);
                    alert('Push failed: ' + error);
                    // Re-enable button on error
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-eject"></i>';
                    }
                },
                complete: function () {
                    // Clear lock after a short delay to allow for grid refresh
                    setTimeout(function() {
                        delete pushInProgress[key];
                    }, 2000);
                }
            });
        }

        var deleteInProgress = false;  // Track delete operation

        function confirmDeletePowerBank(powerBankIdNum, powerBankName, event) {
            // Stop event propagation to prevent grid refresh interference
            if (event) {
                event.stopPropagation();
                event.preventDefault();
            }

            // Show confirmation modal with name
            $('#deletePbId').text(powerBankName || powerBankIdNum);
            $('#deletePbIdHidden').val(powerBankIdNum);
            var modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            modal.show();
        }

        function deletePowerBank() {
            if (deleteInProgress) {
                console.log('Delete already in progress');
                return;
            }

            deleteInProgress = true;
            var powerBankId = $('#deletePbIdHidden').val();

            // Disable the delete button in modal
            var btn = document.querySelector('#deleteConfirmModal .btn-danger');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Deleting...';
            }

            $.ajax({
                type: "POST",
                url: '@Url.Action("DeletePowerBank", "PowerBanks")',
                contentType: 'application/json',
                data: JSON.stringify({ PowerBankId: powerBankId }),
                success: function(response) {
                    // Hide modal
                    bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();

                    if (response.success) {
                        // Show success message and refresh
                        alert('PowerBank deleted successfully');
                        refresh();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();
                    alert('Failed to delete powerbank');
                },
                complete: function() {
                    deleteInProgress = false;
                    // Reset button state
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = 'Delete';
                    }
                }
            });
        }

