            ]

        };


        var dataAdapter = new $.jqx.dataAdapter(source);

        // Create slot grid (reusable for init and update)
        function createSlotGrid(gridElement, slotData, deviceName) {
            var slotSource = {
                datatype: "array",
                datafields: [
                    { name: 'Slot', type: 'number' },
                    { name: 'Status', type: 'string' },
                    { name: 'PowerBankId', type: 'string' },
                    { name: 'PowerBankIdNum', type: 'string' },
                    { name: 'UserId', type: 'string' },
                    { name: 'Plugged', type: 'boolean' },
                    { name: 'Locked', type: 'boolean' },
                    { name: 'Charging', type: 'boolean' },
                    { name: 'IsOk', type: 'boolean' },
                    { name: 'ChargeLevel', type: 'number' },
                    { name: 'LastGetTime', type: 'date' },
                    { name: 'LastPutTime', type: 'date' },
                    { name: 'Duration', type: 'string' }
                ],
                localdata: slotData
            };

            var slotAdapter = new $.jqx.dataAdapter(slotSource);

            // Cell renderer - uses slotData from closure
            function slotCellRenderer(row, column, value) {
                var data = slotData[row];
                if (!data) return "";
                var backcolor = "#FFFFFF";

                // Color by status
                if (data.Status === "On hands") backcolor = "#FEF3C7";
                else if (data.Status === "Returned") backcolor = "#D1FAE5";
                else if (data.Status === "Returned (Offline)" || data.Status === "In station (Offline)") backcolor = "#E5E7EB";
                else if (data.Status === "Offline") backcolor = "#FEE2E2";
                else if (data.Status === "Empty") backcolor = "#F9FAFB";
                else backcolor = "#F3F4F6";

                var divStyle = "<div style='height: 100%; min-height: 36px; background: " + backcolor + "; display: flex; align-items: center; padding: 0 8px;'>";

                if (column === 'Slot') {
                    return divStyle + "<span class='status-circle purple'>" + value + "</span></div>";
                }
                if (column === 'Status') {
                    var badgeClass = 'badge-secondary';
                    var icon = 'fa-question-circle';
                    if (value === "On hands") { badgeClass = 'badge-warning'; icon = 'fa-hand-holding'; }
                    else if (value === "Returned") { badgeClass = 'badge-success'; icon = 'fa-check-circle'; }
                    else if (value === "Returned (Offline)") { badgeClass = 'badge-secondary'; icon = 'fa-check-circle'; }
                    else if (value === "In station (Offline)") { badgeClass = 'badge-secondary'; icon = 'fa-charging-station'; }
                    else if (value === "Offline") { badgeClass = 'badge-danger'; icon = 'fa-wifi'; }
                    else if (value === "In station") { badgeClass = 'badge-info'; icon = 'fa-charging-station'; }
                    else if (value === "Empty") { badgeClass = 'badge-secondary'; icon = 'fa-minus'; }
                    return divStyle + "<span class='slot-badge " + badgeClass + "'><i class='fas " + icon + " me-1'></i>" + value + "</span></div>";
                }
                if (column === 'PowerBankId') {
                    if (!value) return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var pbIdNum = data.PowerBankIdNum || '';
                    return divStyle +
                        "<a href='javascript:void(0)' onclick=\"goToPowerBank('" + pbIdNum + "', event)\" " +
                        "style='font-family: monospace; font-size: 0.75rem; color: #7C3AED; text-decoration: none; cursor: pointer;' " +
                        "onmouseover=\"this.style.textDecoration='underline'\" onmouseout=\"this.style.textDecoration='none'\">" + value + "</a></div>";
                }
                if (column === 'UserId') {
                    if (!value) return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    return divStyle + "<span style='font-size: 0.8rem;'><i class='fas fa-user me-1' style='color: #7C3AED;'></i>" + value + "</span></div>";
                }
                if (column === 'Plugged' || column === 'Locked' || column === 'Charging' || column === 'IsOk') {
                    if (data.Status === 'Empty') return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var circleClass = value ? 'green' : 'gray';
                    if (column === 'IsOk' && !value) circleClass = 'red';
                    return divStyle + "<span class='status-circle " + circleClass + "'></span></div>";
                }
                if (column === 'ChargeLevel') {
                    if (data.Status === 'Empty') return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var level = value || 0;
                    var color = level > 60 ? '#22C55E' : (level > 30 ? '#F59E0B' : '#EF4444');
                    return divStyle +
                        "<div style='display: flex; align-items: center; gap: 6px;'>" +
                        "<div style='width: 40px; height: 6px; background: #E5E7EB; border-radius: 3px; overflow: hidden;'>" +
                        "<div style='width: " + level + "%; height: 100%; background: " + color + ";'></div></div>" +
                        "<span style='font-size: 0.7rem; color: " + color + ";'>" + level + "%</span></div></div>";
                }
                if (column === 'LastGetTime') {
                    if (!value || data.Status === 'Empty') return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var date = new Date(value);
                    if (date.getFullYear() < 2000) return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var formatted = date.toLocaleDateString('ru-RU') + ' ' + date.toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'});
                    return divStyle + "<span style='font-size: 0.75rem;'><i class='fas fa-sign-out-alt me-1' style='color: #F59E0B;'></i>" + formatted + "</span></div>";
                }
                if (column === 'LastPutTime') {
                    if (!value || data.Status === 'Empty') return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var date = new Date(value);
                    if (date.getFullYear() < 2000) return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    var formatted = date.toLocaleDateString('ru-RU') + ' ' + date.toLocaleTimeString('ru-RU', {hour: '2-digit', minute:'2-digit'});
                    return divStyle + "<span style='font-size: 0.75rem;'><i class='fas fa-sign-in-alt me-1' style='color: #10B981;'></i>" + formatted + "</span></div>";
                }
                if (column === 'Duration') {
                    if (!value || value === '-' || data.Status === 'Empty') return divStyle + "<span style='color: #9CA3AF;'>-</span></div>";
                    return divStyle + "<span style='font-size: 0.8rem;'><i class='fas fa-clock me-1' style='color: #6B7280;'></i>" + value + "</span></div>";
                }
                if (column === 'Push') {
                    // Don't show Push button if not plugged or station is offline
                    if (!data.Plugged || data.Status.indexOf('Offline') !== -1) return divStyle + "</div>";
                    return divStyle +
                        "<button class='btn-grid btn-grid-success' style='padding: 4px 10px; font-size: 0.75rem;' " +
                        "onclick=\"PushPB('" + data.DeviceName + "','" + data.Slot + "', event)\">" +
                        "<i class='fas fa-eject'></i></button></div>";
                }
                if (column === 'Delete') {
                    if (data.Status !== 'Offline' && data.Status !== 'On hands') return divStyle + "</div>";
                    return divStyle +
                        "<button class='btn-grid btn-grid-danger' style='padding: 4px 10px; font-size: 0.75rem;' " +
                        "onclick=\"confirmDeletePowerBank('" + data.PowerBankIdNum + "', '" + data.PowerBankId + "', event)\" title='Delete powerbank'>" +
                        "<i class='fas fa-trash'></i></button></div>";
                }
                return divStyle + (value || '-') + "</div>";
            }

            gridElement.jqxGrid({
                width: '100%',
                height: 220,
                source: slotAdapter,
                theme: 'material-purple',
                sortable: false,
                filterable: false,
                rowsheight: 40,
                columnsresize: false,  // Disable resize to prevent freezing in nested grid
                enablebrowserselection: true,
                columns: [
                    { text: "Slot", datafield: "Slot", width: 45, cellsrenderer: slotCellRenderer },
                    { text: "Status", datafield: "Status", width: 95, cellsrenderer: slotCellRenderer },
                    { text: "PowerBank", datafield: "PowerBankId", width: 125, cellsrenderer: slotCellRenderer },
                    { text: "User", datafield: "UserId", width: 85, cellsrenderer: slotCellRenderer },
                    { text: "Plugged", datafield: "Plugged", width: 50, cellsrenderer: slotCellRenderer },
                    { text: "Locked", datafield: "Locked", width: 50, cellsrenderer: slotCellRenderer },
                    { text: "Charging", datafield: "Charging", width: 55, cellsrenderer: slotCellRenderer },
                    { text: "IsOk", datafield: "IsOk", width: 40, cellsrenderer: slotCellRenderer },
                    { text: "Charge", datafield: "ChargeLevel", width: 70, cellsrenderer: slotCellRenderer },
                    { text: "Duration", datafield: "Duration", width: 65, cellsrenderer: slotCellRenderer },
                    { text: "Last Get", datafield: "LastGetTime", width: 120, cellsrenderer: slotCellRenderer },
                    { text: "Last Put", datafield: "LastPutTime", width: 120, cellsrenderer: slotCellRenderer },
                    { text: "Push", datafield: "Push", width: 50, cellsrenderer: slotCellRenderer },
                    { text: "Del", datafield: "Delete", width: 45, cellsrenderer: slotCellRenderer }
                ]
            });
        }

        // Initialize row details (slot information)
        function initSlotDetails(index, parentElement, gridElement, record) {
            var slotInfo = source.localdata[index].SlotInfo || [];
            var deviceName = source.localdata[index].DeviceName;
            var container = $($(parentElement).children()[0]);

            // Create unique grid ID using DeviceName (stable across updates)
            var gridId = 'slotgrid_' + deviceName;
            container.html('<div id="' + gridId + '"></div>');

            // Prepare slot data
            var slotData = [];
            for (var i = 0; i < 4; i++) {
                var slot = slotInfo[i] || { Slot: i + 1, HasPowerBank: false, Status: 'Empty' };
                slot.DeviceName = deviceName;
                slotData.push(slot);
            }

            createSlotGrid($('#' + gridId), slotData, deviceName);
        }

