        function refresh() {
            // Skip refresh if user is currently editing a field
            if (isUserEditing) {
                return;
            }

            $.ajax({
                type: "POST",
                url: '@Url.Action("Refresh", "Devices")',
                contentType: 'application/json',
                data: JSON.stringify({ cnt: 0 }),
                success: function(Data) {
                    // Double-check user isn't editing before updating
                    if (isUserEditing) {
                        return;
                    }

                    var strData = JSON.stringify(Data,
                        function(key, value) {
                            if (value && typeof value === 'object') {
                                var replacement = {};
                                for (var k in value) {
                                    if (Object.hasOwnProperty.call(value, k)) {
                                        replacement[k && k.charAt(0).toUpperCase() + k.substring(1)] = value[k];
                                    }
                                }
                                return replacement;
                            }
                            return value;
                        });
                    source.localdata = Data;
                    if (!newdata) {
                        $("#jqxgrid").jqxGrid({ source: source });
                        newdata = true;
                    }

                    //
                    //$("#jqxgrid").trigger('reloadGrid');
                    //!$("#jqxgrid").jqxGrid('refresh');
                    //$("#jqxgrid").jqxGrid('updatebounddata', 'sort');
                    $("#jqxgrid").jqxGrid('updatebounddata', 'cells');

                    // Re-apply offline filter if active (this may collapse rows)
                    if (hideOffline) {
                        var filtergroup = new $.jqx.filter();
                        var filter = filtergroup.createfilter('booleanfilter', true, 'EQUAL');
                        filtergroup.addfilter(0, filter);
                        $("#jqxgrid").jqxGrid('addfilter', 'Online', filtergroup);
                        $("#jqxgrid").jqxGrid('applyfilters');
                    }

                    // Re-expand rows that were expanded before update (by DeviceName)
                    // Use setTimeout to ensure filters are applied first
                    setTimeout(function() {
                        for (var deviceName in expandedRows) {
                            if (expandedRows[deviceName]) {
                                // Find row index by DeviceName in visible rows
                                var rows = $("#jqxgrid").jqxGrid('getrows');
                                for (var i = 0; i < rows.length; i++) {
                                    if (rows[i].DeviceName === deviceName) {
                                        $("#jqxgrid").jqxGrid('showrowdetails', i);
                                        break;
                                    }
                                }
                            }
                        }
                        // Update expanded slot grids
                        updateExpandedSlotGrids();
                    }, 50);
                }
            });
        }

        // Track expanded rows by DeviceName (not by index, which can change after filtering)
        var expandedRows = {};  // { deviceName: rowIndex }

        function updateExpandedSlotGrids() {
            // Find current data for each expanded device
            for (var deviceName in expandedRows) {
                if (!expandedRows[deviceName]) continue;

                // Find device in current data by DeviceName
                var deviceData = null;
                for (var i = 0; i < source.localdata.length; i++) {
                    if (source.localdata[i].DeviceName === deviceName) {
                        deviceData = source.localdata[i];
                        break;
                    }
                }

                if (!deviceData) continue;

                var slotInfo = deviceData.SlotInfo || [];
                var gridId = 'slotgrid_' + deviceName;
                var grid = $('#' + gridId);

                if (grid.length > 0) {
                    // Prepare updated slot data
                    var slotData = [];
                    for (var i = 0; i < 4; i++) {
                        var slot = slotInfo[i] || { Slot: i + 1, HasPowerBank: false, Status: 'Empty' };
                        slot.DeviceName = deviceName;
                        slotData.push(slot);
                    }

                    // Save reference to parent before destroy
                    var parentContainer = grid.parent();

                    // Destroy and recreate grid to force full re-render
                    try {
                        grid.jqxGrid('destroy');
                    } catch(e) {}

                    // Recreate the grid container
                    parentContainer.html('<div id="' + gridId + '"></div>');
                    grid = $('#' + gridId);

                    // Create fresh grid with new data
                    createSlotGrid(grid, slotData, deviceName);
                }
            }
        }


        function sleep(milliseconds) {
            const date = Date.now();
            let currentDate = null;
            do {
                currentDate = Date.now();
            } while (currentDate - date < milliseconds);
        }


