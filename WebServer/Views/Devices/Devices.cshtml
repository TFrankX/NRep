            var isCompact = localStorage.getItem('devicesCompactView') === 'true';
            if (isCompact) {
                setCompactView(true);
                $('#viewToggle').addClass('active');
                $('#viewToggleText').text('Full View');
                $('#viewToggleIcon').removeClass('fa-compress').addClass('fa-expand');
            }

            // Check saved offline filter preference
            if (hideOffline) {
                // Apply filter after a small delay to ensure grid is ready
                setTimeout(function() {
                    applyOfflineFilter();
                    updateOfflineButton();
                }, 500);
            }
        });

        // Columns to hide in compact view
        var compactHiddenColumns = ['Id_str', 'HostDeviceId_str', 'Online', 'CanRegister', 'Registered', 'Owners', 'UserLocation', 'PushPB'];

        function setCompactView(compact) {
            compactHiddenColumns.forEach(function(col) {
                $("#jqxgrid").jqxGrid('hidecolumn', col);
                if (!compact) {
                    $("#jqxgrid").jqxGrid('showcolumn', col);
                }
            });
            if (compact) {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('hidecolumn', col);
                });
            }
        }

        function toggleView() {
            var isCompact = localStorage.getItem('devicesCompactView') === 'true';
            isCompact = !isCompact;
            localStorage.setItem('devicesCompactView', isCompact);

            if (isCompact) {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('hidecolumn', col);
                });
                $('#viewToggle').addClass('active');
                $('#viewToggleText').text('Full View');
                $('#viewToggleIcon').removeClass('fa-compress').addClass('fa-expand');
            } else {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('showcolumn', col);
                });
                $('#viewToggle').removeClass('active');
                $('#viewToggleText').text('Compact');
                $('#viewToggleIcon').removeClass('fa-expand').addClass('fa-compress');
            }
        }

        // Toggle offline stations visibility
        var hideOffline = localStorage.getItem('devicesHideOffline') === 'true';

        function toggleOffline() {
            hideOffline = !hideOffline;
            localStorage.setItem('devicesHideOffline', hideOffline);
            applyOfflineFilter();
            updateOfflineButton();
        }

        function applyOfflineFilter() {
            if (hideOffline) {
                var filtergroup = new $.jqx.filter();
                var filter = filtergroup.createfilter('booleanfilter', true, 'EQUAL');
                filtergroup.addfilter(0, filter);
                $("#jqxgrid").jqxGrid('addfilter', 'Online', filtergroup);
                $("#jqxgrid").jqxGrid('applyfilters');
            } else {
                $("#jqxgrid").jqxGrid('removefilter', 'Online');
                $("#jqxgrid").jqxGrid('applyfilters');
            }
        }

        function updateOfflineButton() {
            if (hideOffline) {
                $('#offlineToggle').addClass('active');
                $('#offlineToggleText').text('Show Offline');
                $('#offlineToggleIcon').removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                $('#offlineToggle').removeClass('active');
                $('#offlineToggleText').text('Hide Offline');
                $('#offlineToggleIcon').removeClass('fa-eye-slash').addClass('fa-eye');
            }
        }


        function addElement(parentId, elementTag, elementId, html) {
            // Adds an element to the document
            var p = document.getElementById(parentId);
            var newElement = document.createElement(elementTag);
            newElement.setAttribute('id', elementId);
            newElement.innerHTML = html;
            p.appendChild(newElement);
        }

        function removeElement(elementId) {
            // Removes an element from the document
            var element = document.getElementById(elementId);
            element.parentNode.removeChild(element);
        }

        function _createWindow() {
            var jqxWidget = $('#jqxWidget');
            var offset = jqxWidget.offset();
            $('#deviceSettings').jqxWindow({
                position: { x: offset.left + 50, y: offset.top + 50 },
                showCollapseButton: true,
                maxHeight: 600,
                maxWidth: 900,
                minHeight: 200,
                minWidth: 400,
                height: 600,
                width: 900,
                initContent: function() {
                    //$('#tab').jqxTabs({ height: '100%', width:  '100%' });
                    $('#deviceSettings').jqxWindow('focus');
                },
                autoOpen: false
            });

            $('#jqxgrid').on('rowclick', function (event) {
                // event.args.rowindex is a bound index.
                alert("Row with bound index: " + event.args.rowindex + " has been clicked.");
            });

            // $('#chartWindow').jqxWindow('close');
        };

    </script>

}



