@section scripts
{
    <script type="text/javascript">
        var serverAddress = '@serverAddress';
        var qrModalInstance = null;

        function closeQRModal() {
            if (qrModalInstance) {
                qrModalInstance.hide();
            }
            // Also try jQuery method as fallback
            $('#qrModal').modal('hide');
        }

        function showQRCode(deviceId, deviceName) {
            var url = 'https://' + serverAddress + '/User/Do?deviceId=' + deviceId;

            $('#qrDeviceName').text(deviceName || 'Station ' + deviceId);
            $('#qrLink').attr('href', url).text(url);
            $('#qrcode').empty();

            // Generate QR code using qrcodejs library
            var qrcode = new QRCode(document.getElementById('qrcode'), {
                text: url,
                width: 256,
                height: 256,
                colorDark: '#7C3AED',
                colorLight: '#FFFFFF',
                correctLevel: QRCode.CorrectLevel.H
            });

            qrModalInstance = new bootstrap.Modal(document.getElementById('qrModal'));
            qrModalInstance.show();
        }

        function downloadQR() {
            var canvas = $('#qrcode canvas')[0];
            var img = $('#qrcode img')[0];

            if (canvas) {
                var link = document.createElement('a');
                link.download = 'qrcode-' + $('#qrDeviceName').text() + '.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
            } else if (img) {
                var link = document.createElement('a');
                link.download = 'qrcode-' + $('#qrDeviceName').text() + '.png';
                link.href = img.src;
                link.click();
            }
        }

        function printQR() {
            var deviceName = $('#qrDeviceName').text();
            var qrLink = $('#qrLink').attr('href');
            var img = $('#qrcode img')[0];
            var canvas = $('#qrcode canvas')[0];
            var qrSrc = '';

            if (canvas) {
                qrSrc = canvas.toDataURL('image/png');
            } else if (img) {
                qrSrc = img.src;
            }

            var printWindow = window.open('', '_blank');
            var html = '<!DOCTYPE html>' +
                '<html><head><title>QR Code - ' + deviceName + '</title>' +
                '<style>' +
                'body{font-family:Arial,sans-serif;margin:15px;padding:0}' +
                '.container{text-align:left;border:1px solid #7C3AED;border-radius:8px;padding:12px;display:inline-block}' +
                '.header{display:flex;align-items:center;margin-bottom:8px}' +
                '.logo{font-size:12px;font-weight:bold;color:#7C3AED}' +
                '.logo-icon{display:inline-block;width:18px;height:18px;background:#7C3AED;color:white;border-radius:4px;line-height:18px;text-align:center;margin-right:5px;font-size:10px}' +
                '.device-name{font-size:11px;font-weight:600;color:#333;margin-left:10px}' +
                '.qr-wrapper{position:relative;display:inline-block;padding:6px;background:white;border-radius:6px}' +
                '.qr-wrapper img{display:block;width:80px;height:80px}' +
                '.qr-logo{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:16px;height:16px;background:#7C3AED;border-radius:50%;border:2px solid white;display:flex;align-items:center;justify-content:center;color:white;font-size:8px}' +
                '.url{color:#7C3AED;font-size:7px;word-break:break-all;margin-top:6px;max-width:80px}' +
                '</style></head>' +
                '<body><div class="container">' +
                '<div class="header"><div class="logo"><span class="logo-icon">⚡</span>A-Charger</div><span class="device-name">' + deviceName + '</span></div>' +
                '<div class="qr-wrapper"><img src="' + qrSrc + '" alt="QR Code"><div class="qr-logo">⚡</div></div>' +
                '<div class="url">' + qrLink + '</div>' +
                '</div>' +
                '<script>window.onload=function(){window.print();window.onafterprint=function(){window.close();};};<\/script>' +
                '</body></html>';
            printWindow.document.write(html);
            printWindow.document.close();
        }

