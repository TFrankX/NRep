                { name: 'Owners', type: 'string' },
                { name: 'SimId', type: 'string' },
                { name: 'LastOnlineTime', type: 'date' },
            ]

        };


        var dataAdapter = new $.jqx.dataAdapter(source);


        $(document).ready(function() {


            $("#jqxgrid").jqxGrid(
                {
                    width: '100%',
                    source: dataAdapter,
                    theme: 'material-purple',
                    sortable: true,
                    filterable: true,
                    //showfilterrow: true,
                    //autorowheight: true,
                    rowsheight: 44,
                    //autorowheight: true,
                    enablebrowserselection: true,
                    selectionmode: 'multiplecellsadvanced',
                    //autoheight: true,
                    //pageable: true,
                    height: 720,
                    columnsresize: true,
                    autowidth: true,
                    columns: [
                        { text: "ID", datafield: "Id_str", width: 160, cellsrenderer: cellsrenderer },
                        { text: "Device", datafield: "DeviceName", width: 170, cellsrenderer: cellsrenderer },
                        { text: "Host ID", datafield: "HostDeviceId_str", width: 160, cellsrenderer: cellsrenderer },
                        { text: "Online", datafield: "Online", width: 60, cellsrenderer: cellsrenderer },
                        { text: "Slots", datafield: "Slots", width: 155, cellsrenderer: cellsrenderer },
                        { text: "Active", datafield: "Activated", width: 60, cellsrenderer: cellsrenderer },
                        { text: "CanReg", datafield: "CanRegister", width: 60, cellsrenderer: cellsrenderer },
                        { text: "Reg", datafield: "Registered", width: 50, cellsrenderer: cellsrenderer },
                        { text: "Type", datafield: "TypeOfUse", width: 120, cellsrenderer: cellsrenderer },
                        { text: "Description", datafield: "Description", width: 220, cellsrenderer: cellsrenderer },
                        { text: "Owner", datafield: "Owners", width: 70, cellsrenderer: cellsrenderer, columntype: 'textbox' },
                        { text: "SIM", datafield: "SimId", width: 180, cellsrenderer: cellsrenderer },
                        { text: "Last Online", datafield: "LastOnlineTime", width: 160, cellsrenderer: cellsrenderer },
                        { text: "Push", datafield: "PushPB", width: 80, cellsrenderer: cellsrenderer },
                        { text: "QR", datafield: "QR", width: 60, cellsrenderer: cellsrenderer },
                     ]
                });
            refresh();
            $("#jqxWidget").css('display', 'block');

            // Check saved view preference
            var isCompact = localStorage.getItem('devicesCompactView') === 'true';
            if (isCompact) {
                setCompactView(true);
                $('#viewToggle').addClass('active');
                $('#viewToggleText').text('Full View');
                $('#viewToggleIcon').removeClass('fa-compress').addClass('fa-expand');
            }
        });

        // Columns to hide in compact view
        var compactHiddenColumns = ['Id_str', 'HostDeviceId_str', 'Online', 'CanRegister', 'Registered', 'Owners', 'PushPB'];

        function setCompactView(compact) {
            compactHiddenColumns.forEach(function(col) {
                $("#jqxgrid").jqxGrid('hidecolumn', col);
                if (!compact) {
                    $("#jqxgrid").jqxGrid('showcolumn', col);
                }
            });
            if (compact) {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('hidecolumn', col);
                });
            }
        }

        function toggleView() {
            var isCompact = localStorage.getItem('devicesCompactView') === 'true';
            isCompact = !isCompact;
            localStorage.setItem('devicesCompactView', isCompact);

            if (isCompact) {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('hidecolumn', col);
                });
                $('#viewToggle').addClass('active');
                $('#viewToggleText').text('Full View');
                $('#viewToggleIcon').removeClass('fa-compress').addClass('fa-expand');
            } else {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('showcolumn', col);
                });
                $('#viewToggle').removeClass('active');
                $('#viewToggleText').text('Compact');
                $('#viewToggleIcon').removeClass('fa-expand').addClass('fa-compress');
            }
        }


        function addElement(parentId, elementTag, elementId, html) {
            // Adds an element to the document
            var p = document.getElementById(parentId);
            var newElement = document.createElement(elementTag);
            newElement.setAttribute('id', elementId);
            newElement.innerHTML = html;
            p.appendChild(newElement);
        }

        function removeElement(elementId) {
            // Removes an element from the document
            var element = document.getElementById(elementId);
            element.parentNode.removeChild(element);
        }

        function _createWindow() {
            var jqxWidget = $('#jqxWidget');
            var offset = jqxWidget.offset();
            $('#deviceSettings').jqxWindow({
                position: { x: offset.left + 50, y: offset.top + 50 },
                showCollapseButton: true,
                maxHeight: 600,
                maxWidth: 900,
                minHeight: 200,
                minWidth: 400,
                height: 600,
                width: 900,
                initContent: function() {
                    //$('#tab').jqxTabs({ height: '100%', width:  '100%' });
                    $('#deviceSettings').jqxWindow('focus');
                },
                autoOpen: false
            });

            $('#jqxgrid').on('rowclick', function (event) {
                // event.args.rowindex is a bound index.
                alert("Row with bound index: " + event.args.rowindex + " has been clicked.");
            });

            // $('#chartWindow').jqxWindow('close');
        };

    </script>

}



