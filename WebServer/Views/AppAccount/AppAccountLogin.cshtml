@model AppAccountsLogin
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - A-Charger</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/acharger-theme.css" />
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="~/favicon.png" />
</head>
<body class="login-page">
    <div class="login-card fade-in">
        <div class="login-logo">
            <h1>
                <span class="logo-icon">
                    <i class="fas fa-bolt"></i>
                </span>
                A-Charger
            </h1>
        </div>

        <div class="login-title">
            <h2>Welcome back</h2>
            <p>Sign in to your account</p>
        </div>

        <form method="post" asp-controller="AppAccount" asp-action="AppAccountLogin"
              asp-route-returnUrl="@Model.ReturnUrl" asp-route-newStationId="@Model.NewStationId" class="login-form">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="form-group-acharger">
                <label asp-for="UserName">
                    <i class="fas fa-user me-1"></i>Username
                </label>
                <input asp-for="UserName" class="form-control-acharger" placeholder="Enter your username" />
                <span asp-validation-for="UserName" class="text-danger-acharger" style="font-size: 0.875rem;"></span>
            </div>

            <div class="form-group-acharger">
                <label asp-for="Password">
                    <i class="fas fa-lock me-1"></i>Password
                </label>
                <input asp-for="Password" class="form-control-acharger" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger-acharger" style="font-size: 0.875rem;"></span>
            </div>

            <button type="submit" class="btn-acharger btn-primary-acharger btn-login">
                <i class="fas fa-sign-in-alt"></i>
                Sign In
            </button>

            <div class="d-grid gap-2 mt-3">
                <a href="@Url.Action("AppAccountLoginSMS", "AppAccount", new { NewStationId = Model.NewStationId })"
                   class="btn-acharger btn-secondary-acharger">
                    <i class="fas fa-sms"></i>
                    Sign in with SMS
                </a>
            </div>
        </form>

        <div class="login-footer">
            <p>
                Don't have an account?
                <a href="@Url.Action("AppCreateSelfAccount", "AppAccountManagement", new { NewStationId = Model.NewStationId })">
                    Create one
                </a>
            </p>
        </div>

        @if (Model.NewStationId > 0)
        {
            <div class="mt-4 p-3" style="background: var(--accent-light); border-radius: var(--border-radius-sm);">
                <small class="text-primary-acharger">
                    <i class="fas fa-info-circle me-1"></i>
                    New station ID: <strong>@Model.NewStationId</strong>
                </small>
            </div>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
