        font-weight: 500;
    }

    .detail-group input {
        padding: 8px 12px;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-size: 14px;
    }

    .detail-group input:focus {
        outline: none;
        border-color: #7C3AED;
        box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
    }

    .details-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding-top: 16px;
        border-top: 1px solid #E5E7EB;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    .btn-icon.btn-delete {
        background: #FEE2E2;
        color: #DC2626;
    }

    .btn-icon.btn-delete:hover {
        background: #FECACA;
    }

    .btn-save {
        padding: 10px 20px;
        background: #7C3AED;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-save:hover {
        background: #5B21B6;
    }

    .btn-cancel {
        padding: 10px 20px;
        background: #F3F4F6;
        color: #4B5563;
        border: none;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cancel:hover {
        background: #E5E7EB;
    }

    .btn-add-server {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 14px;
        background: white;
        border: 2px dashed #D1D5DB;
        border-radius: 0 0 12px 12px;
        color: #6B7280;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-add-server:hover {
        border-color: #7C3AED;
        color: #7C3AED;
        background: #F5F3FF;
    }

    .add-server-form {
        padding: 24px;
        background: #F9FAFB;
        border-top: 1px solid #E5E7EB;
    }

    .add-server-form h4 {
        margin: 0 0 20px 0;
        color: #1F2937;
        font-size: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .add-server-form h4 i {
        color: #7C3AED;
    }

    .add-server-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
    }

    .no-servers-message {
        padding: 60px 20px;
        text-align: center;
        color: #9CA3AF;
    }

    .no-servers-message i {
        font-size: 48px;
        margin-bottom: 16px;
        display: block;
    }

    .no-servers-message p {
        margin: 0;
        font-size: 14px;
    }

    /* Certificate Upload Styles */
    .cert-upload-group {
        grid-column: span 1;
    }

    .cert-upload-row {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .cert-upload-row input[type="text"] {
        flex: 1;
        background: #F9FAFB;
        color: #6B7280;
        font-size: 12px;
    }

    .btn-upload {
        padding: 8px 12px;
        background: #7C3AED;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-upload:hover {
        background: #5B21B6;
    }

    .btn-cert-delete {
        padding: 8px 10px;
        background: #FEE2E2;
        color: #DC2626;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-cert-delete:hover {
        background: #FECACA;
    }

    .detail-group.full-width {
        grid-column: 1 / -1;
    }

    .detail-group.full-width label {
        color: #9CA3AF;
        font-style: italic;
    }

    .detail-group.full-width label i {
        margin-right: 6px;
    }

    /* Test Connection Styles */
    .btn-test {
        padding: 10px 20px;
        background: #F3F4F6;
        color: #374151;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-test:hover {
        background: #E5E7EB;
        border-color: #9CA3AF;
    }

    .btn-test.testing {
        background: #FEF3C7;
        border-color: #F59E0B;
        color: #92400E;
    }

    .btn-test.testing i {
        animation: spin 1s linear infinite;
    }

    .test-result {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
    }

    .test-result.success {
        background: #ECFDF5;
        color: #059669;
    }

    .test-result.success i {
        color: #10B981;
    }

    .test-result.error {
        background: #FEF2F2;
        color: #DC2626;
    }

    .test-result.error i::before {
        content: "\f057";
    }

    .details-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
        padding-top: 16px;
        border-top: 1px solid #E5E7EB;
        flex-wrap: wrap;
    }

    /* Toggle Switch */
    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

    .switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.3s;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: 0.3s;
    }

    input:checked + .slider {
        background-color: #7C3AED;
    }

    input:checked + .slider:before {
        transform: translateX(24px);
    }

    .slider.round {
        border-radius: 26px;
    }

    .slider.round:before {
        border-radius: 50%;
    }
</style>

<div class="page-header">
    <h2><i class="fas fa-cog"></i> Settings</h2>
</div>

<div class="settings-container">
    <div class="settings-sidebar">
        <nav class="settings-nav">
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "pricing" ? "active" : "")" data-section="pricing">
                <i class="fas fa-tags"></i>
                <span>Pricing Plans</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "support" ? "active" : "")" data-section="support">
                <i class="fas fa-headset"></i>
                <span>Support</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "notifications" ? "active" : "")" data-section="notifications">
                <i class="fas fa-bell"></i>
                <span>Notifications</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "servers" ? "active" : "")" data-section="servers">
                <i class="fas fa-server"></i>
                <span>Servers</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "system" ? "active" : "")" data-section="system">
                <i class="fas fa-cogs"></i>
                <span>System</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "integrations" ? "active" : "")" data-section="integrations">
                <i class="fas fa-plug"></i>
                <span>Integrations</span>
            </a>
        </nav>
    </div>

    <div class="settings-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Pricing Section -->
        <div id="section-pricing" class="settings-section @(Model.ActiveSection == "pricing" ? "active" : "")" style="@(Model.ActiveSection == "pricing" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Pricing Plans</h2>
                <p>Configure rental rates and fees for each pricing plan. Changes take effect immediately.</p>
            </div>

            <div class="pricing-grid">
                @foreach (var plan in Model.PricingPlans)
                {
                    <div class="pricing-card">
                        <div class="pricing-card-header">
                            <h4>@plan.DisplayName</h4>
                            <span class="plan-id">@plan.PlanName</span>
                        </div>
                        <div class="pricing-card-body">
                            <div class="setting-row">
                                <span class="setting-label">Display Name</span>
                                <input type="text" class="setting-input wide" id="@(plan.PlanName)_DisplayName" value="@plan.DisplayName">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Hold Amount</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_HoldAmount" value="@plan.HoldAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Base Fee</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_BaseFee" value="@plan.BaseFee.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Hourly Rate</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_HourlyRate" value="@plan.HourlyRate.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Daily Rate</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_DailyRate" value="@plan.DailyRate.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Max Days</span>
                                <input type="number" class="setting-input" id="@(plan.PlanName)_MaxDaysBeforeCapture" value="@plan.MaxDaysBeforeCapture">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Currency</span>
                                <select class="setting-input" id="@(plan.PlanName)_Currency">
                                    @if (plan.Currency == "eur") {
                                        <option value="eur" selected>EUR</option>
                                    } else {
                                        <option value="eur">EUR</option>
                                    }
                                    @if (plan.Currency == "usd") {
                                        <option value="usd" selected>USD</option>
                                    } else {
                                        <option value="usd">USD</option>
                                    }
                                    @if (plan.Currency == "gbp") {
                                        <option value="gbp" selected>GBP</option>
                                    } else {
                                        <option value="gbp">GBP</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="pricing-card-footer">
                            <button type="button" class="btn-save-plan" id="save_@plan.PlanName" onclick="savePricingPlan('@plan.PlanName')">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Support Section -->
        <div id="section-support" class="settings-section" style="@(Model.ActiveSection == "support" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Support Contacts</h2>
                <p>Configure support phone and email displayed to customers.</p>
            </div>

            <div class="system-card" style="max-width: 500px;">
                <div class="system-card-header">
                    <i class="fas fa-headset"></i>
                    <div>
                        <h4>Customer Support</h4>
                        <p>Contact information for customers</p>
                    </div>
                </div>
                <div class="system-card-body">
                    <div class="setting-row">
                        <span class="setting-label">Phone Number</span>
                        <input type="tel" class="setting-input wide" id="support_phone" value="@Model.Support.Phone" placeholder="+357 99 123 456">
                    </div>
                    <div class="setting-row">
                        <span class="setting-label">Email</span>
                        <input type="email" class="setting-input wide" id="support_email" value="@Model.Support.Email" placeholder="support@example.com">
                    </div>
                    <div class="setting-row">
                        <span class="setting-label">Working Hours</span>
                        <input type="text" class="setting-input wide" id="support_hours" value="@Model.Support.WorkingHours" placeholder="24/7">
                    </div>
                </div>
                <div class="system-card-footer">
                    <button type="button" class="btn-save-plan" id="save_support" onclick="saveSupportSettings()">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- Notifications Section -->
        <div id="section-notifications" class="settings-section" style="@(Model.ActiveSection == "notifications" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Notifications</h2>
                <p>Configure email and SMS notification settings.</p>
            </div>
            <div class="coming-soon">
                <i class="fas fa-bell"></i>
                <h3>Coming Soon</h3>
                <p>Notification settings will be available in a future update.</p>
            </div>
        </div>

        <!-- Servers Section -->
        <div id="section-servers" class="settings-section" style="@(Model.ActiveSection == "servers" ? "display: block;" : "")">
            <div class="section-header">
                <h2>MQTT Servers</h2>
                <p>Configure MQTT servers for charging stations. Maximum 5 servers.</p>
            </div>

            <div class="servers-table-container">
                <table class="servers-table" id="serversTable">
                    <thead>
                        <tr>
                            <th style="width: 40px;"></th>
                            <th>Address</th>
                            <th>Port</th>
                            <th>Status</th>
                            <th style="width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var server in Model.Servers)
                        {
                            <tr class="server-row" data-index="@server.Index">
                                <td class="expand-cell" onclick="toggleServerDetails(@server.Index)">
                                    <i class="fas fa-chevron-right expand-icon" id="expand-icon-@server.Index"></i>
                                </td>
                                <td onclick="toggleServerDetails(@server.Index)"><strong>@server.Address</strong></td>
                                <td onclick="toggleServerDetails(@server.Index)">@server.Port</td>
                                <td onclick="toggleServerDetails(@server.Index)">
                                    <span class="server-status-badge @(server.Enabled ? "enabled" : "disabled")">
                                        @(server.Enabled ? "Enabled" : "Disabled")
                                    </span>
                                </td>
                                <td>
                                    <button type="button" class="btn-icon btn-delete" onclick="deleteServerConfig(@server.Index)" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr class="server-details" id="server-details-@server.Index" style="display: none;">
                                <td colspan="5">
                                    <div class="server-details-content">
                                        <div class="details-grid">
                                            <div class="detail-group">
                                                <label>Address</label>
                                                <input type="text" id="server@(server.Index)_address" value="@server.Address" placeholder="mqtt.example.com">
                                            </div>
                                            <div class="detail-group">
                                                <label>Port</label>
                                                <input type="number" id="server@(server.Index)_port" value="@server.Port" placeholder="8884">
                                            </div>
                                            <div class="detail-group">
                                                <label>Username</label>
                                                <input type="text" id="server@(server.Index)_user" value="@server.User" placeholder="username">
                                            </div>
                                            <div class="detail-group">
                                                <label>Password</label>
                                                <input type="password" id="server@(server.Index)_pass" value="@server.Pass" placeholder="password">
                                            </div>
                                            <div class="detail-group">
                                                <label>Reconnect (sec)</label>
                                                <input type="number" id="server@(server.Index)_reconnect" value="@server.ReconnectTime" placeholder="30">
                                            </div>
                                            <div class="detail-group cert-upload-group">
                                                <label>CA Certificate</label>
                                                <div class="cert-upload-row">
                                                    <input type="text" id="server@(server.Index)_certca" value="@server.CertCA" placeholder="No certificate" readonly>
                                                    <input type="file" id="server@(server.Index)_certca_file" accept=".crt,.pem,.cer" style="display:none" onchange="uploadCertificate(@server.Index, 'ca', this)">
                                                    <button type="button" class="btn-upload" onclick="$('#server@(server.Index)_certca_file').click()">
                                                        <i class="fas fa-upload"></i>
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(server.CertCA))
                                                    {
                                                        <button type="button" class="btn-cert-delete" onclick="deleteCertificate(@server.Index, 'ca')">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <div class="detail-group cert-upload-group">
                                                <label>Client Certificate</label>
                                                <div class="cert-upload-row">
                                                    <input type="text" id="server@(server.Index)_certcli" value="@server.CertCli" placeholder="No certificate" readonly>
                                                    <input type="file" id="server@(server.Index)_certcli_file" accept=".crt,.pem,.p12,.pfx,.key" style="display:none" onchange="uploadCertificate(@server.Index, 'client', this)">
                                                    <button type="button" class="btn-upload" onclick="$('#server@(server.Index)_certcli_file').click()">
                                                        <i class="fas fa-upload"></i>
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(server.CertCli))
                                                    {
                                                        <button type="button" class="btn-cert-delete" onclick="deleteCertificate(@server.Index, 'client')">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <div class="detail-group">
                                                <label>Certificate Password</label>
                                                <input type="password" id="server@(server.Index)_certpass" value="@server.CertPass" placeholder="password (if required)">
                                            </div>
                                            <div class="detail-group">
                                                <label>Enabled</label>
                                                <label class="switch">
                                                    <input type="checkbox" id="server@(server.Index)_enabled" @(server.Enabled ? "checked" : "")>
                                                    <span class="slider round"></span>
                                                </label>
                                            </div>
                                        </div>
                                        <div class="details-actions">
                                            <button type="button" class="btn-test" id="btn-test-@server.Index" onclick="testServerConnection(@server.Index)">
                                                <i class="fas fa-plug"></i> Test Connection
                                            </button>
                                            <div class="test-result" id="test-result-@server.Index" style="display: none;">
                                                <i class="fas fa-check-circle"></i>
                                                <span class="test-message"></span>
                                            </div>
                                            <button type="button" class="btn-save" onclick="saveServerConfig(@server.Index)">
                                                <i class="fas fa-save"></i> Save Changes
                                            </button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.Servers.Count < 5)
                {
                    <button type="button" class="btn-add-server" onclick="showAddServerForm()">
                        <i class="fas fa-plus"></i> Add Server
                    </button>
                }

                <!-- Add Server Form (hidden by default) -->
                <div id="addServerForm" class="add-server-form" style="display: none;">
                    <h4><i class="fas fa-server"></i> New Server</h4>
                    <div class="details-grid">
                        <div class="detail-group">
                            <label>Address *</label>
                            <input type="text" id="new_server_address" placeholder="mqtt.example.com">
                        </div>
                        <div class="detail-group">
                            <label>Port</label>
                            <input type="number" id="new_server_port" value="8884" placeholder="8884">
                        </div>
                        <div class="detail-group">
                            <label>Username</label>
                            <input type="text" id="new_server_user" placeholder="username">
                        </div>
                        <div class="detail-group">
                            <label>Password</label>
                            <input type="password" id="new_server_pass" placeholder="password">
                        </div>
                        <div class="detail-group">
                            <label>Reconnect (sec)</label>
                            <input type="number" id="new_server_reconnect" value="30" placeholder="30">
                        </div>
                        <div class="detail-group">
                            <label>Certificate Password</label>
                            <input type="password" id="new_server_certpass" placeholder="password (if required)">
                        </div>
                        <div class="detail-group full-width">
                            <label><i class="fas fa-info-circle"></i> Certificates can be uploaded after adding the server</label>
                        </div>
                        <div class="detail-group">
                            <label>Enabled</label>
                            <label class="switch">
                                <input type="checkbox" id="new_server_enabled" checked>
                                <span class="slider round"></span>
                            </label>
                        </div>
                    </div>
                    <div class="add-server-actions">
                        <button type="button" class="btn-cancel" onclick="hideAddServerForm()">Cancel</button>
                        <button type="button" class="btn-save" onclick="addNewServer()">
                            <i class="fas fa-plus"></i> Add Server
                        </button>
                    </div>
                </div>

                @if (Model.Servers.Count == 0)
                {
                    <div class="no-servers-message">
                        <i class="fas fa-server"></i>
                        <p>No servers configured yet. Click "Add Server" to get started.</p>
                    </div>
                }
            </div>
        </div>

        <!-- System Section -->
        <div id="section-system" class="settings-section" style="@(Model.ActiveSection == "system" ? "display: block;" : "")">
            <div class="section-header">
                <h2>System Settings</h2>
                <p>Configure system-wide parameters and defaults.</p>
            </div>

            <div class="system-card">
                <div class="system-card-header">
                    <i class="fas fa-database"></i>
                    <div>
                        <h4>Database Reload</h4>
                        <p>Reload devices and powerbanks data from database</p>
                    </div>
                </div>
                <div class="system-card-body">
                    <p class="text-muted">
                        Use this if you have manually added or modified records in the database.
                        The system will reload all Devices and PowerBanks from the database without restarting.
                    </p>
                    <div class="reload-result" id="reloadResult" style="display: none;">
                        <i class="fas fa-check-circle"></i>
                        <span id="reloadResultText"></span>
                    </div>
                </div>
                <div class="system-card-footer">
                    <button type="button" class="btn-reload" id="btnReloadDb" onclick="reloadDatabase()">
                        <i class="fas fa-sync-alt"></i> Reload Database
                    </button>
                </div>
            </div>
        </div>

        <!-- Integrations Section -->
        <div id="section-integrations" class="settings-section" style="@(Model.ActiveSection == "integrations" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Integrations</h2>
                <p>Configure third-party service integrations (Stripe, SMS, etc.).</p>
            </div>
            <div class="coming-soon">
                <i class="fas fa-plug"></i>
                <h3>Coming Soon</h3>
                <p>Integration settings will be available in a future update.</p>
            </div>
        </div>
    </div>
</div>
