@model WebServer.Models.Settings.SettingsViewModel

@{
    ViewData["Title"] = "Settings";
}

@section Scripts
{
    <script type="text/javascript">
        function savePricingPlan(planName) {
            var plan = {
                PlanName: planName,
                DisplayName: $(`#${planName}_DisplayName`).val(),
                HoldAmount: parseFloat($(`#${planName}_HoldAmount`).val()),
                BaseFee: parseFloat($(`#${planName}_BaseFee`).val()),
                HourlyRate: parseFloat($(`#${planName}_HourlyRate`).val()),
                DailyRate: parseFloat($(`#${planName}_DailyRate`).val()),
                MaxDaysBeforeCapture: parseInt($(`#${planName}_MaxDaysBeforeCapture`).val()),
                Currency: $(`#${planName}_Currency`).val()
            };

            var btn = $(`#save_${planName}`);
            var originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SavePricingPlanAjax", "Settings")',
                contentType: 'application/json',
                data: JSON.stringify(plan),
                success: function(response) {
                    btn.html('<i class="fas fa-check"></i> Saved!').removeClass('btn-primary').addClass('btn-success');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-success').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error').removeClass('btn-primary').addClass('btn-danger');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-danger').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                    alert('Failed to save: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function switchSection(section) {
            $('.settings-nav-item').removeClass('active');
            $(`.settings-nav-item[data-section="${section}"]`).addClass('active');
            $('.settings-section').hide();
            $(`#section-${section}`).show();
            history.replaceState(null, '', `?section=${section}`);
        }

        $(document).ready(function() {
            $('.settings-nav-item').click(function(e) {
                e.preventDefault();
                var section = $(this).data('section');
                switchSection(section);
            });
        });
    </script>
}

<style>
    .settings-container {
        display: flex;
        gap: 24px;
        min-height: calc(100vh - 200px);
    }

    .settings-sidebar {
        width: 250px;
        flex-shrink: 0;
    }

    .settings-nav {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .settings-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        color: #4B5563;
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: all 0.2s;
    }

    .settings-nav-item:hover {
        background: #F9FAFB;
        color: #7C3AED;
    }

    .settings-nav-item.active {
        background: #F3E8FF;
        color: #7C3AED;
        border-left-color: #7C3AED;
        font-weight: 500;
    }

    .settings-nav-item i {
        width: 20px;
        text-align: center;
    }

    .settings-content {
        flex: 1;
    }

    .settings-section {
        display: none;
    }

    .settings-section.active {
        display: block;
    }

    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    .pricing-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .pricing-card-header {
        background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
        color: white;
        padding: 16px 20px;
    }

    .pricing-card-header h4 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }

    .pricing-card-header .plan-id {
        font-size: 12px;
        opacity: 0.8;
    }

    .pricing-card-body {
        padding: 20px;
    }

    .setting-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #F3F4F6;
    }

    .setting-row:last-child {
        border-bottom: none;
    }

    .setting-label {
        font-size: 13px;
        color: #6B7280;
    }

    .setting-input {
        width: 100px;
        padding: 6px 10px;
        border: 1px solid #E5E7EB;
        border-radius: 6px;
        font-size: 14px;
        text-align: right;
    }

    .setting-input:focus {
        outline: none;
        border-color: #7C3AED;
        box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
    }

    .setting-input.wide {
        width: 140px;
    }

    .pricing-card-footer {
        padding: 16px 20px;
        background: #F9FAFB;
        border-top: 1px solid #F3F4F6;
    }

    .btn-save-plan {
        width: 100%;
        padding: 10px;
        background: #7C3AED;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-save-plan:hover {
        background: #5B21B6;
    }

    .section-header {
        margin-bottom: 24px;
    }

    .section-header h2 {
        font-size: 24px;
        font-weight: 600;
        color: #1F2937;
        margin: 0;
    }

    .section-header p {
        color: #6B7280;
        margin: 8px 0 0 0;
    }

    .coming-soon {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        padding: 60px 40px;
        text-align: center;
    }

    .coming-soon i {
        font-size: 48px;
        color: #D1D5DB;
        margin-bottom: 16px;
    }

    .coming-soon h3 {
        color: #6B7280;
        font-weight: 500;
    }
</style>

<div class="page-header">
    <h2><i class="fas fa-cog"></i> Settings</h2>
</div>

<div class="settings-container">
    <div class="settings-sidebar">
        <nav class="settings-nav">
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "pricing" ? "active" : "")" data-section="pricing">
                <i class="fas fa-tags"></i>
                <span>Pricing Plans</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "notifications" ? "active" : "")" data-section="notifications">
                <i class="fas fa-bell"></i>
                <span>Notifications</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "system" ? "active" : "")" data-section="system">
                <i class="fas fa-server"></i>
                <span>System</span>
            </a>
            <a href="#" class="settings-nav-item @(Model.ActiveSection == "integrations" ? "active" : "")" data-section="integrations">
                <i class="fas fa-plug"></i>
                <span>Integrations</span>
            </a>
        </nav>
    </div>

    <div class="settings-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Pricing Section -->
        <div id="section-pricing" class="settings-section @(Model.ActiveSection == "pricing" ? "active" : "")" style="@(Model.ActiveSection == "pricing" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Pricing Plans</h2>
                <p>Configure rental rates and fees for each pricing plan. Changes take effect immediately.</p>
            </div>

            <div class="pricing-grid">
                @foreach (var plan in Model.PricingPlans)
                {
                    <div class="pricing-card">
                        <div class="pricing-card-header">
                            <h4>@plan.DisplayName</h4>
                            <span class="plan-id">@plan.PlanName</span>
                        </div>
                        <div class="pricing-card-body">
                            <div class="setting-row">
                                <span class="setting-label">Display Name</span>
                                <input type="text" class="setting-input wide" id="@(plan.PlanName)_DisplayName" value="@plan.DisplayName">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Hold Amount</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_HoldAmount" value="@plan.HoldAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Base Fee</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_BaseFee" value="@plan.BaseFee.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Hourly Rate</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_HourlyRate" value="@plan.HourlyRate.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Daily Rate</span>
                                <input type="number" step="0.01" class="setting-input" id="@(plan.PlanName)_DailyRate" value="@plan.DailyRate.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Max Days</span>
                                <input type="number" class="setting-input" id="@(plan.PlanName)_MaxDaysBeforeCapture" value="@plan.MaxDaysBeforeCapture">
                            </div>
                            <div class="setting-row">
                                <span class="setting-label">Currency</span>
                                <select class="setting-input" id="@(plan.PlanName)_Currency">
                                    @if (plan.Currency == "eur") {
                                        <option value="eur" selected>EUR</option>
                                    } else {
                                        <option value="eur">EUR</option>
                                    }
                                    @if (plan.Currency == "usd") {
                                        <option value="usd" selected>USD</option>
                                    } else {
                                        <option value="usd">USD</option>
                                    }
                                    @if (plan.Currency == "gbp") {
                                        <option value="gbp" selected>GBP</option>
                                    } else {
                                        <option value="gbp">GBP</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="pricing-card-footer">
                            <button type="button" class="btn-save-plan" id="save_@plan.PlanName" onclick="savePricingPlan('@plan.PlanName')">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Notifications Section -->
        <div id="section-notifications" class="settings-section" style="@(Model.ActiveSection == "notifications" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Notifications</h2>
                <p>Configure email and SMS notification settings.</p>
            </div>
            <div class="coming-soon">
                <i class="fas fa-bell"></i>
                <h3>Coming Soon</h3>
                <p>Notification settings will be available in a future update.</p>
            </div>
        </div>

        <!-- System Section -->
        <div id="section-system" class="settings-section" style="@(Model.ActiveSection == "system" ? "display: block;" : "")">
            <div class="section-header">
                <h2>System Settings</h2>
                <p>Configure system-wide parameters and defaults.</p>
            </div>
            <div class="coming-soon">
                <i class="fas fa-server"></i>
                <h3>Coming Soon</h3>
                <p>System settings will be available in a future update.</p>
            </div>
        </div>

        <!-- Integrations Section -->
        <div id="section-integrations" class="settings-section" style="@(Model.ActiveSection == "integrations" ? "display: block;" : "")">
            <div class="section-header">
                <h2>Integrations</h2>
                <p>Configure third-party service integrations (Stripe, SMS, etc.).</p>
            </div>
            <div class="coming-soon">
                <i class="fas fa-plug"></i>
                <h3>Coming Soon</h3>
                <p>Integration settings will be available in a future update.</p>
            </div>
        </div>
    </div>
</div>
