@model WebServer.Models.Settings.SettingsViewModel

@{
    ViewData["Title"] = "Settings";
}

@section Scripts
{
    <script type="text/javascript">
        function savePricingPlan(planName) {
            // Helper to parse numbers with comma or dot as decimal separator
            function parseNumber(val) {
                if (!val) return 0;
                return parseFloat(val.toString().replace(',', '.')) || 0;
            }

            var plan = {
                PlanName: planName,
                DisplayName: $(`#${planName}_DisplayName`).val(),
                HoldAmount: parseNumber($(`#${planName}_HoldAmount`).val()),
                BaseFee: parseNumber($(`#${planName}_BaseFee`).val()),
                HourlyRate: parseNumber($(`#${planName}_HourlyRate`).val()),
                DailyRate: parseNumber($(`#${planName}_DailyRate`).val()),
                MaxDaysBeforeCapture: parseInt($(`#${planName}_MaxDaysBeforeCapture`).val()) || 0,
                Currency: $(`#${planName}_Currency`).val()
            };

            var btn = $(`#save_${planName}`);
            var originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SavePricingPlanAjax", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify(plan),
                success: function(response) {
                    btn.html('<i class="fas fa-check"></i> Saved!').removeClass('btn-primary').addClass('btn-success');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-success').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error').removeClass('btn-primary').addClass('btn-danger');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-danger').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                    alert('Failed to save: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function switchSection(section) {
            $('.settings-nav-item').removeClass('active');
            $(`.settings-nav-item[data-section="${section}"]`).addClass('active');
            $('.settings-section').hide();
            $(`#section-${section}`).show();
            history.replaceState(null, '', `?section=${section}`);
        }

        $(document).ready(function() {
            $('.settings-nav-item').click(function(e) {
                e.preventDefault();
                var section = $(this).data('section');
                switchSection(section);
            });
        });

        function saveSupportSettings() {
            var support = {
                Phone: $('#support_phone').val(),
                Email: $('#support_email').val(),
                WorkingHours: $('#support_hours').val()
            };

            var btn = $('#save_support');
            var originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveSupportSettingsAjax", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify(support),
                success: function(response) {
                    btn.html('<i class="fas fa-check"></i> Saved!').removeClass('btn-primary').addClass('btn-success');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-success').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error').removeClass('btn-primary').addClass('btn-danger');
                    setTimeout(function() {
                        btn.html(originalText).removeClass('btn-danger').addClass('btn-primary').prop('disabled', false);
                    }, 2000);
                    alert('Failed to save: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function reloadDatabase() {
            var btn = $('#btnReloadDb');
            var resultDiv = $('#reloadResult');
            var resultText = $('#reloadResultText');

            btn.html('<i class="fas fa-sync-alt"></i> Reloading...').addClass('loading').prop('disabled', true);
            resultDiv.hide();

            $.ajax({
                type: "POST",
                url: '@Url.Action("ReloadDatabase", "Settings")',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    btn.html('<i class="fas fa-check"></i> Done!').removeClass('loading');
                    resultDiv.removeClass('error').addClass('success').show();
                    resultText.text('Loaded ' + response.devices + ' devices and ' + response.powerBanks + ' powerbanks');

                    setTimeout(function() {
                        btn.html('<i class="fas fa-sync-alt"></i> Reload Database').prop('disabled', false);
                    }, 3000);
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error').removeClass('loading');
                    resultDiv.removeClass('success').addClass('error').show();
                    resultText.text(xhr.responseJSON?.message || 'Failed to reload database');

                    setTimeout(function() {
                        btn.html('<i class="fas fa-sync-alt"></i> Reload Database').prop('disabled', false);
                    }, 3000);
                }
            });
        }

        function toggleServerDetails(index) {
            var details = $(`#server-details-${index}`);
            var icon = $(`#expand-icon-${index}`);

            if (details.is(':visible')) {
                details.slideUp(200);
                icon.removeClass('expanded');
            } else {
                // Close other open details
                $('.server-details').slideUp(200);
                $('.expand-icon').removeClass('expanded');

                details.slideDown(200);
                icon.addClass('expanded');
            }
        }

        function saveServerConfig(index) {
            var server = {
                Index: index,
                Address: $(`#server${index}_address`).val(),
                Port: parseInt($(`#server${index}_port`).val()) || 8884,
                User: $(`#server${index}_user`).val(),
                Pass: $(`#server${index}_pass`).val(),
                ReconnectTime: parseInt($(`#server${index}_reconnect`).val()) || 30,
                CertCA: $(`#server${index}_certca`).val(),
                CertCli: $(`#server${index}_certcli`).val(),
                CertPass: $(`#server${index}_certpass`).val(),
                Enabled: $(`#server${index}_enabled`).is(':checked')
            };

            if (!server.Address) {
                alert('Server address is required');
                return;
            }

            var btn = $(`#server-details-${index} .btn-save`);
            var originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Saving...').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveServerConfigAjax", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify(server),
                success: function(response) {
                    btn.html('<i class="fas fa-check"></i> Saved!');

                    // Update the row display
                    var row = $(`.server-row[data-index="${index}"]`);
                    row.find('td:eq(1) strong').text(server.Address);
                    row.find('td:eq(2)').text(server.Port);

                    var statusBadge = row.find('.server-status-badge');
                    statusBadge.removeClass('enabled disabled')
                        .addClass(server.Enabled ? 'enabled' : 'disabled')
                        .text(server.Enabled ? 'Enabled' : 'Disabled');

                    setTimeout(function() {
                        btn.html(originalText).prop('disabled', false);
                    }, 2000);
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error');
                    setTimeout(function() {
                        btn.html(originalText).prop('disabled', false);
                    }, 2000);
                    alert('Failed to save: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function deleteServerConfig(index) {
            event.stopPropagation();

            if (!confirm('Are you sure you want to delete this server?')) {
                return;
            }

            $.ajax({
                type: "POST",
                url: '@Url.Action("DeleteServerConfigAjax", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify({ Index: index }),
                success: function(response) {
                    // Remove the row and details
                    $(`.server-row[data-index="${index}"]`).remove();
                    $(`#server-details-${index}`).remove();

                    // Show add button if hidden
                    if ($('.server-row').length < 5) {
                        $('.btn-add-server').show();
                    }

                    // Show no servers message if empty
                    if ($('.server-row').length === 0) {
                        $('.servers-table').hide();
                        if ($('.no-servers-message').length === 0) {
                            $('.servers-table-container').append(
                                '<div class="no-servers-message">' +
                                '<i class="fas fa-server"></i>' +
                                '<p>No servers configured yet. Click "Add Server" to get started.</p>' +
                                '</div>'
                            );
                        }
                    }
                },
                error: function(xhr) {
                    alert('Failed to delete: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function showAddServerForm() {
            $('#addServerForm').slideDown(200);
            $('.btn-add-server').hide();
        }

        function hideAddServerForm() {
            $('#addServerForm').slideUp(200);
            $('.btn-add-server').show();

            // Clear form
            $('#new_server_address').val('');
            $('#new_server_port').val('8884');
            $('#new_server_user').val('');
            $('#new_server_pass').val('');
            $('#new_server_reconnect').val('30');
            $('#new_server_certca').val('');
            $('#new_server_certcli').val('');
            $('#new_server_certpass').val('');
            $('#new_server_enabled').prop('checked', true);
        }

        function addNewServer() {
            var address = $('#new_server_address').val();
            if (!address) {
                alert('Server address is required');
                return;
            }

            // Find first available index
            var usedIndexes = [];
            $('.server-row').each(function() {
                usedIndexes.push(parseInt($(this).data('index')));
            });

            var newIndex = 0;
            for (var i = 0; i < 5; i++) {
                if (usedIndexes.indexOf(i) === -1) {
                    newIndex = i;
                    break;
                }
            }

            var server = {
                Index: newIndex,
                Address: address,
                Port: parseInt($('#new_server_port').val()) || 8884,
                User: $('#new_server_user').val(),
                Pass: $('#new_server_pass').val(),
                ReconnectTime: parseInt($('#new_server_reconnect').val()) || 30,
                CertCA: '',
                CertCli: '',
                CertPass: $('#new_server_certpass').val(),
                Enabled: $('#new_server_enabled').is(':checked')
            };

            var btn = $('#addServerForm .btn-save');
            var originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Adding...').prop('disabled', true);

            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveServerConfigAjax", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify(server),
                success: function(response) {
                    // Reload the page to show new server
                    location.reload();
                },
                error: function(xhr) {
                    btn.html('<i class="fas fa-times"></i> Error');
                    setTimeout(function() {
                        btn.html(originalText).prop('disabled', false);
                    }, 2000);
                    alert('Failed to add: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }

        function testServerConnection(index) {
            var server = {
                Index: index,
                Address: $(`#server${index}_address`).val(),
                Port: parseInt($(`#server${index}_port`).val()) || 8884,
                User: $(`#server${index}_user`).val(),
                Pass: $(`#server${index}_pass`).val(),
                ReconnectTime: parseInt($(`#server${index}_reconnect`).val()) || 30,
                CertCA: $(`#server${index}_certca`).val(),
                CertCli: $(`#server${index}_certcli`).val(),
                CertPass: $(`#server${index}_certpass`).val(),
                Enabled: true
            };

            if (!server.Address) {
                alert('Server address is required');
                return;
            }

            var btn = $(`#btn-test-${index}`);
            var result = $(`#test-result-${index}`);
            var originalText = btn.html();

            btn.html('<i class="fas fa-spinner fa-spin"></i> Testing...').addClass('testing').prop('disabled', true);
            result.hide();

            $.ajax({
                type: "POST",
                url: '@Url.Action("TestServerConnection", "Settings")',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                data: JSON.stringify(server),
                success: function(response) {
                    btn.html(originalText).removeClass('testing').prop('disabled', false);

                    result.find('.test-message').text(response.message);

                    if (response.success) {
                        result.removeClass('error').addClass('success');
                        result.find('i').removeClass('fa-times-circle').addClass('fa-check-circle');
                    } else {
                        result.removeClass('success').addClass('error');
                        result.find('i').removeClass('fa-check-circle').addClass('fa-times-circle');
                    }

                    result.show();

                    // Hide result after 10 seconds
                    setTimeout(function() {
                        result.fadeOut();
                    }, 10000);
                },
                error: function(xhr) {
                    btn.html(originalText).removeClass('testing').prop('disabled', false);

                    result.find('.test-message').text(xhr.responseJSON?.message || 'Connection test failed');
                    result.removeClass('success').addClass('error');
                    result.find('i').removeClass('fa-check-circle').addClass('fa-times-circle');
                    result.show();
                }
            });
        }

        function uploadCertificate(serverIndex, certType, input) {
            if (!input.files || !input.files[0]) return;

            var file = input.files[0];
            var formData = new FormData();
            formData.append('file', file);
            formData.append('serverIndex', serverIndex);
            formData.append('certType', certType);

            var inputId = certType === 'ca' ? `server${serverIndex}_certca` : `server${serverIndex}_certcli`;
            var $input = $(`#${inputId}`);
            $input.val('Uploading...');

            $.ajax({
                type: "POST",
                url: '@Url.Action("UploadCertificate", "Settings")',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    $input.val(response.path);

                    // Add delete button if not exists
                    var $row = $input.closest('.cert-upload-row');
                    if ($row.find('.btn-cert-delete').length === 0) {
                        $row.append(`<button type="button" class="btn-cert-delete" onclick="deleteCertificate(${serverIndex}, '${certType}')"><i class="fas fa-times"></i></button>`);
                    }

                    // Show success feedback
                    $input.css('background', '#ECFDF5');
                    setTimeout(function() {
                        $input.css('background', '#F9FAFB');
                    }, 2000);
                },
                error: function(xhr) {
                    $input.val('');
                    alert('Failed to upload: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });

            // Clear file input
            input.value = '';
        }

        function deleteCertificate(serverIndex, certType) {
            if (!confirm('Delete this certificate?')) return;

            var inputId = certType === 'ca' ? `server${serverIndex}_certca` : `server${serverIndex}_certcli`;
            var $input = $(`#${inputId}`);

            $.ajax({
                type: "POST",
                url: '@Url.Action("DeleteCertificate", "Settings")',
                data: { serverIndex: serverIndex, certType: certType },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    $input.val('');
                    $input.closest('.cert-upload-row').find('.btn-cert-delete').remove();
                },
                error: function(xhr) {
                    alert('Failed to delete: ' + (xhr.responseJSON?.message || 'Unknown error'));
                }
            });
        }
    </script>
}

@Html.AntiForgeryToken()

<style>
    .settings-container {
        display: flex;
        gap: 24px;
        min-height: calc(100vh - 200px);
    }

    .settings-sidebar {
        width: 250px;
        flex-shrink: 0;
    }

    .settings-nav {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .settings-nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        color: #4B5563;
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: all 0.2s;
    }

    .settings-nav-item:hover {
