@{
    ViewData["Title"] = "Actions";
}

@section scripts
{
    <script type="text/javascript">


        function cellsrenderer(row, column, value) {
            var jsonmod = source.localdata;
            var backcolor = "#FFFFFF";

            var divstartstyle = "<div style='height: 100%; min-height: 36px; width: 100%; background: " + backcolor + "; display: flex; align-items: center; padding: 0 8px;'>";

            // Date/time column
            if (column === 'ActionTime') {
                function checkZero(data) {
                    if (data < 10) {
                        data = "0" + data;
                    }
                    return data;
                }
                var year = value.getFullYear();
                var month = checkZero(value.getMonth() + 1);
                var day = checkZero(value.getDate());
                var hour = checkZero(value.getHours());
                var min = checkZero(value.getMinutes());
                var sec = checkZero(value.getSeconds());
                var svalue = year + '/' + month + '/' + day + " " + hour + ":" + min + ":" + sec;

                return divstartstyle +
                    "<span style='font-size: 0.8rem; color: #6B7280;'>" + svalue + "</span>" +
                    "</div>";
            }

            // Action code
            if (column === 'ActionCode') {
                var code = value || 0;
                var codeHex = '0x' + code.toString(16).toUpperCase();
                return divstartstyle +
                    "<span class='type-badge' style='background: #EDE9FE; color: #7C3AED;'>" + codeHex + "</span>" +
                    "</div>";
            }

            // User ID
            if (column === 'UserId') {
                return divstartstyle +
                    "<span style='font-size: 0.8rem;'>" + (value || '-') + "</span>" +
                    "</div>";
            }

            // ID columns (smaller font, muted)
            if (column === 'ActionServerId' || column === 'ActionStationId' || column === 'ActionPowerBankId') {
                return divstartstyle +
                    "<span style='font-size: 0.75rem; color: #6B7280;'>" + (value || '-') + "</span>" +
                    "</div>";
            }

            // Slot
            if (column === 'ActionPowerBankSlot') {
                if (value && value > 0) {
                    return divstartstyle +
                        "<span class='status-circle purple' style='width: 20px; height: 20px; font-size: 0.65rem;'>" + value + "</span>" +
                        "</div>";
                }
                return divstartstyle + "<span>-</span></div>";
            }

            // Action text
            if (column === 'ActionText') {
                return divstartstyle +
                    "<span style='font-size: 0.85rem;'>" + (value || '') + "</span>" +
                    "</div>";
            }

            // Payment amount
            if (column === 'PaymentAmount') {
                if (value && value > 0) {
                    return divstartstyle +
                        "<span style='font-weight: 600; color: #059669;'>" + value.toFixed(2) + " EUR</span>" +
                        "</div>";
                }
                return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
            }

            // Payment info
            if (column === 'PaymentInfo') {
                if (value && value.length > 0) {
                    return divstartstyle +
                        "<span style='font-size: 0.75rem; color: #6B7280;'>" + value + "</span>" +
                        "</div>";
                }
                return divstartstyle + "<span style='color: #9CA3AF;'>-</span></div>";
            }

            // Default
            return divstartstyle +
                "<span style='font-size: 0.85rem;'>" + value + "</span>" +
                "</div>";
        }


        var isFirstLoad = true;

        function showLoader() {
            if (isFirstLoad) {
                $('#loadingOverlay').fadeIn(200);
            }
        }

        function hideLoader() {
            $('#loadingOverlay').fadeOut(300);
            isFirstLoad = false;
        }

        // Текущий период и пользовательские даты
        var currentPeriod = 'day';
        var customFromDate = null;
        var customToDate = null;

        function refresh() {
            showLoader();

            var url = '@Url.Action("Refresh", "Actions")' + '?period=' + currentPeriod;
            if (customFromDate && customToDate) {
                url = '@Url.Action("Refresh", "Actions")' + '?fromDate=' + customFromDate.toISOString() + '&toDate=' + customToDate.toISOString();
            }

            $.ajax({
                type: "GET",
                url: url,
                success: function(Data) {
                    source.localdata = Data;
                    if (!newdata) {
                        $("#jqxgrid").jqxGrid({ source: source });
                        newdata = true;
                        $("#jqxgrid").jqxGrid('autoresizecolumn', 'ActionText');
                    }
                    $("#jqxgrid").jqxGrid('updatebounddata', 'data');
                    $('#recordCount').text(Data.length + ' records');
                    hideLoader();
                },
                error: function() {
                    hideLoader();
                }
            });
        }

        function setPeriod(period) {
            currentPeriod = period;
            customFromDate = null;
            customToDate = null;

            // Обновляем активную кнопку
            $('.period-btn').removeClass('active');
            $('#btn-' + period).addClass('active');
            $('#customRangeInfo').hide();

            refresh();
        }

        function applyCustomRange() {
            var fromDate = $('#dateFrom').jqxDateTimeInput('getDate');
            var toDate = $('#dateTo').jqxDateTimeInput('getDate');

            if (fromDate && toDate) {
                customFromDate = fromDate;
                customToDate = toDate;
                currentPeriod = 'custom';

                $('.period-btn').removeClass('active');
                $('#customRangeInfo').show().text(
                    fromDate.toLocaleDateString() + ' - ' + toDate.toLocaleDateString()
                );

                refresh();
            }
        }


        function sleep(milliseconds) {
            const date = Date.now();
            let currentDate = null;
            do {
                currentDate = Date.now();
            } while (currentDate - date < milliseconds);
        }


        var minDateVal = null;
        var maxDateVal = null;
        var serverData;
        var newdata = false;
        var prevChartData = "";
        var grid = $("#jqxgrid"),
            intervalId = setInterval(refresh, 3000);

        var source =
        {
            datatype: "json",
            datafields: [
                { name: 'ActionTime', type: 'date' },
                { name: 'ActionCode', type: 'numeric' },
                { name: 'UserId', type: 'string' },
                { name: 'DeviceName', type: 'string' },
                { name: 'PowerBankName', type: 'string' },
                { name: 'ActionPowerBankSlot', type: 'string' },
                { name: 'ActionText', type: 'string' },
                { name: 'PaymentAmount', type: 'float' },
                { name: 'PaymentInfo', type: 'string' }
            ]

        };

        // Колонки для скрытия в компактном виде
        var compactHiddenColumns = ['ActionCode', 'UserId', 'DeviceName', 'PowerBankName', 'ActionPowerBankSlot', 'PaymentAmount', 'PaymentInfo'];

        function toggleView() {
            var isCompact = localStorage.getItem('actionsCompactView') === 'true';
            isCompact = !isCompact;
            localStorage.setItem('actionsCompactView', isCompact);
            applyView(isCompact);
        }

        function applyView(isCompact) {
            if (isCompact) {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('hidecolumn', col);
                });
                $('#viewToggle').addClass('active');
                $('#viewToggleText').text('Full View');
                $('#viewToggleIcon').removeClass('fa-compress').addClass('fa-expand');
            } else {
                compactHiddenColumns.forEach(function(col) {
                    $("#jqxgrid").jqxGrid('showcolumn', col);
                });
                $('#viewToggle').removeClass('active');
                $('#viewToggleText').text('Compact');
                $('#viewToggleIcon').removeClass('fa-expand').addClass('fa-compress');
            }
        }


        var dataAdapter = new $.jqx.dataAdapter(source);


        $(document).ready(function() {


            $("#jqxgrid").jqxGrid(
                {
                    width: '100%',
                    source: dataAdapter,
                    theme: 'material-purple',
                    sortable: true,
                    filterable: true,
                    rowsheight: 40,
                    enablebrowserselection: true,
                    selectionmode: 'multiplecellsadvanced',
                    height: 720,
                    columnsresize: true,
                    columns: [
                        { text: "Time", datafield: "ActionTime", width: 150, cellsrenderer: cellsrenderer },
                        { text: "Code", datafield: "ActionCode", width: 80, cellsrenderer: cellsrenderer },
                        { text: "User", datafield: "UserId", width: 100, cellsrenderer: cellsrenderer },
                        { text: "Device", datafield: "DeviceName", width: 120, cellsrenderer: cellsrenderer },
                        { text: "PowerBank", datafield: "PowerBankName", width: 120, cellsrenderer: cellsrenderer },
                        { text: "Slot", datafield: "ActionPowerBankSlot", width: 45, cellsrenderer: cellsrenderer },
                        { text: "Action Text", datafield: "ActionText", minwidth: 250, cellsrenderer: cellsrenderer },
                        { text: "Amount", datafield: "PaymentAmount", width: 90, cellsrenderer: cellsrenderer },
                        { text: "Payment Info", datafield: "PaymentInfo", width: 280, cellsrenderer: cellsrenderer },
                     ]
                });
            // Инициализация date picker
            var now = new Date();
            var weekAgo = new Date();
            weekAgo.setDate(weekAgo.getDate() - 7);

            $("#dateFrom").jqxDateTimeInput({
                width: 190,
                height: 32,
                theme: 'material-purple',
                formatString: 'dd.MM.yyyy HH:mm',
                showTimeButton: true,
                value: weekAgo
            });

            $("#dateTo").jqxDateTimeInput({
                width: 190,
                height: 32,
                theme: 'material-purple',
                formatString: 'dd.MM.yyyy HH:mm',
                showTimeButton: true,
                value: now
            });

            refresh();
            $("#jqxWidget").css('display', 'block');

            // Применяем сохранённый режим просмотра
            var isCompact = localStorage.getItem('actionsCompactView') === 'true';
            if (isCompact) {
                applyView(true);
            }
        });


        function addElement(parentId, elementTag, elementId, html) {
            // Adds an element to the document
            var p = document.getElementById(parentId);
            var newElement = document.createElement(elementTag);
            newElement.setAttribute('id', elementId);
            newElement.innerHTML = html;
            p.appendChild(newElement);
        }

        function removeElement(elementId) {
            // Removes an element from the document
            var element = document.getElementById(elementId);
            element.parentNode.removeChild(element);
        }

        function _createWindow() {
            var jqxWidget = $('#jqxWidget');
            var offset = jqxWidget.offset();
            $('#chartWindow').jqxWindow({
                position: { x: offset.left + 50, y: offset.top + 50 },
                showCollapseButton: true,
                maxHeight: 600,
                maxWidth: 900,
                minHeight: 200,
                minWidth: 400,
                height: 600,
                width: 900,
                initContent: function() {
                    //$('#tab').jqxTabs({ height: '100%', width:  '100%' });
                    $('#chartWindow').jqxWindow('focus');
                },
                autoOpen: false
            });


            // $('#chartWindow').jqxWindow('close');
        };

    </script>

    }



    <body class="default">
    <div id="jqxWidget">
        <div style="display: none; width: 100%; height: 650px; margin-top: 50px;" id="mainWinContainer">
            <div id="chartWindow">

                <div id="windowHeader">
                    <span>
                        Chart
                    </span>
                </div>

            </div>
        </div>
    </div>
    </body>



    <style>
        .disable {
            pointer-events: none;
            background: #ccc;
        }

        .yellow {
            background: orange;
            border-color: orange;
        }

        .redCircle {
            width: 24px;
            height: 24px;
            background: red;
            border-radius: 50%;
            margin-left: auto;
            margin-right: auto;
        }

        .greenCircle {
            width: 24px;
            height: 24px;
            background: green;
            border-radius: 50%;
            margin-left: auto;
            margin-right: auto;
        }

        .grayCircle {
            width: 24px;
            height: 24px;
            background: gray;
            border-radius: 50%;
            margin-left: auto;
            margin-right: auto;
        }

        /* Preloader */

        #p_prldr {
            position: fixed;
            left: 0;
            top: 0;
            right: 0;
            bottom: 0;
            background: #0066FF;
            z-index: 30;
        }

        .contpre small {
            font-size: 20px;
            line-height: 24px;
        }

        .contpre {
            width: 250px;
            height: 100px;
            position: absolute;
            left: 50%;
            top: 48%;
            margin-left: -125px;
            margin-top: -75px;
            color: #fff;
            font-size: 32px;
            text-align: center;
            line-height: 36px;
        }

        #p_prldr .svg_anm {
            position: absolute;
            width: 41px;
            height: 41px;
            background: url(/images/tail-spin.svg) center center no-repeat;
            background-size: 41px;
            margin: -16px 0 0 -16px;
        }

        /* Loading Overlay */
        .loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255, 255, 255, 0.9);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            border-radius: 12px;
        }

        .loading-spinner {
            width: 48px;
            height: 48px;
            border: 4px solid #E5E7EB;
            border-top-color: #7C3AED;
            border-radius: 50%;
            animation: spinner 0.8s linear infinite;
        }

        .loading-text {
            margin-top: 16px;
            color: #6B7280;
            font-size: 14px;
            font-weight: 500;
        }

        @@keyframes spinner {
            to { transform: rotate(360deg); }
        }

        .grid-container {
            position: relative;
            overflow-x: auto;
        }

        #jqxgrid {
            min-width: 1200px;
        }

        .filter-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            margin-bottom: 16px;
            padding: 16px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .period-buttons {
            display: flex;
            gap: 8px;
        }

        .period-btn {
            padding: 8px 16px;
            border: 1px solid #E5E7EB;
            background: white;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            color: #6B7280;
            transition: all 0.2s;
        }

        .period-btn:hover {
            border-color: #7C3AED;
            color: #7C3AED;
        }

        .period-btn.active {
            background: #7C3AED;
            border-color: #7C3AED;
            color: white;
        }

        .date-range-picker {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .date-range-picker label {
            font-size: 0.85rem;
            color: #6B7280;
        }

        #customRangeInfo {
            display: none;
            padding: 6px 12px;
            background: #EDE9FE;
            color: #7C3AED;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        #recordCount {
            margin-left: auto;
            font-size: 0.85rem;
            color: #6B7280;
        }
    </style>



<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
    <div>
        <h1><i class="fas fa-list-alt"></i> Actions Log</h1>
        <p class="page-subtitle">System events and user actions</p>
    </div>
    <button id="viewToggle" class="btn-acharger btn-secondary-acharger" onclick="toggleView()" style="white-space: nowrap;">
        <i id="viewToggleIcon" class="fas fa-compress"></i>
        <span id="viewToggleText">Compact</span>
    </button>
</div>

<div class="filter-toolbar">
    <div class="period-buttons">
        <button id="btn-hour" class="period-btn" onclick="setPeriod('hour')">Hour</button>
        <button id="btn-day" class="period-btn active" onclick="setPeriod('day')">Day</button>
        <button id="btn-month" class="period-btn" onclick="setPeriod('month')">Month</button>
        <button id="btn-all" class="period-btn" onclick="setPeriod('all')">All</button>
    </div>
    <div class="date-range-picker">
        <label>From:</label>
        <div id="dateFrom"></div>
        <label>To:</label>
        <div id="dateTo"></div>
        <button class="period-btn" onclick="applyCustomRange()">
            <i class="fas fa-filter"></i> Apply
        </button>
    </div>
    <span id="customRangeInfo"></span>
    <span id="recordCount">0 records</span>
</div>

<div class="grid-container">
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-spinner"></div>
        <div class="loading-text">Loading actions...</div>
    </div>
    <div id="jqxgrid"></div>
</div>


