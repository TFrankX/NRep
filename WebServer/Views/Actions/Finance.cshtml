<script src="~/jqwidgets/jqxcore.js"></script>
<script src="~/jqwidgets/jqxdata.js"></script>
<script src="~/jqwidgets/jqxbuttons.js"></script>
<script src="~/jqwidgets/jqxscrollbar.js"></script>
<script src="~/jqwidgets/jqxgrid.js"></script>
<script src="~/jqwidgets/jqxgrid.edit.js"></script>
<script src="~/jqwidgets/jqxgrid.columnsresize.js"></script>
<script src="~/jqwidgets/jqxgrid.filter.js"></script>
<script src="~/jqwidgets/jqxgrid.selection.js"></script>
<script src="~/jqwidgets/jqxgrid.sort.js"></script>
<script src="~/jqwidgets/jqxgrid.pager.js"></script>
<script src="~/jqwidgets/jqxgrid.aggregates.js"></script>
<script src="~/jqwidgets/jqxmenu.js"></script>
<script src="~/jqwidgets/jqxlistbox.js"></script>
<script src="~/jqwidgets/jqxdropdownlist.js"></script>

<link rel="stylesheet" href="~/jqwidgets/styles/jqx.base.css" type="text/css" />
<link rel="stylesheet" href="~/jqwidgets/styles/jqx.material-purple.css" type="text/css" />
<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
<meta name="viewport" content="width=device-width, initial-scale=1 maximum-scale=1 minimum-scale=1" />

@{
    ViewData["Title"] = "Finance";
}

@section scripts
{
    <script type="text/javascript">

        function cellsrenderer(row, column, value) {
            var jsonmod = source.localdata;
            var backcolor = "#FFFFFF";
            var isTotalRow = jsonmod[row] && jsonmod[row].StationName === "TOTAL";

            if (isTotalRow) {
                backcolor = "#F0FDF4";
            }

            var divstartstyle = "<div style='height: 100%; min-height: 40px; width: 100%; background: " + backcolor + "; display: flex; align-items: center; padding: 0 12px;'>";

            // Station name
            if (column === 'StationName') {
                var fontWeight = isTotalRow ? "700" : "500";
                var fontSize = isTotalRow ? "0.95rem" : "0.875rem";
                return divstartstyle +
                    "<span style='font-weight: " + fontWeight + "; font-size: " + fontSize + ";'>" + value + "</span>" +
                    "</div>";
            }

            // Earnings columns
            if (column === 'MonthEarnings' || column === 'YearEarnings' || column === 'TotalEarnings') {
                var fontWeight = isTotalRow ? "700" : "600";
                var color = value >= 0 ? "#059669" : "#DC2626";
                return divstartstyle +
                    "<span style='font-weight: " + fontWeight + "; color: " + color + ";'>" +
                    value.toFixed(2) + " EUR</span>" +
                    "</div>";
            }

            // Transaction count columns
            if (column === 'MonthTransactions' || column === 'YearTransactions' || column === 'TotalTransactions') {
                var fontWeight = isTotalRow ? "700" : "500";
                return divstartstyle +
                    "<span style='font-weight: " + fontWeight + "; color: #6B7280;'>" + value + "</span>" +
                    "</div>";
            }

            // Default
            return divstartstyle +
                "<span style='font-size: 0.85rem;'>" + value + "</span>" +
                "</div>";
        }

        var isFirstLoad = true;

        function showLoader() {
            if (isFirstLoad) {
                $('#loadingOverlay').fadeIn(200);
            }
        }

        function hideLoader() {
            $('#loadingOverlay').fadeOut(300);
            isFirstLoad = false;
        }

        function refresh() {
            showLoader();
            $.ajax({
                type: "GET",
                url: '@Url.Action("RefreshFinance", "Actions")',
                success: function(Data) {
                    source.localdata = Data;
                    if (!newdata) {
                        $("#jqxgrid").jqxGrid({ source: source });
                        newdata = true;
                    }
                    $("#jqxgrid").jqxGrid('updatebounddata', 'sort');
                    hideLoader();
                },
                error: function() {
                    hideLoader();
                }
            });
        }

        var newdata = false;

        var source =
        {
            datatype: "json",
            datafields: [
                { name: 'StationId', type: 'string' },
                { name: 'StationName', type: 'string' },
                { name: 'MonthEarnings', type: 'float' },
                { name: 'YearEarnings', type: 'float' },
                { name: 'TotalEarnings', type: 'float' },
                { name: 'MonthTransactions', type: 'int' },
                { name: 'YearTransactions', type: 'int' },
                { name: 'TotalTransactions', type: 'int' }
            ]
        };

        var dataAdapter = new $.jqx.dataAdapter(source);

        // Nested grid for transaction details
        var nestedGrids = [];

        function initRowDetails(index, parentElement, gridElement, record) {
            var stationId = record.StationId;
            var isTotalRow = record.StationName === "TOTAL";

            // Skip row details for TOTAL row
            if (isTotalRow || !stationId || stationId === "0") {
                $(parentElement).hide();
                return;
            }

            var nestedGridId = 'nestedGrid_' + index;
            var container = $(parentElement);
            container.html('<div style="margin: 10px;"><div id="' + nestedGridId + '"></div></div>');

            var nestedSource = {
                datatype: "json",
                datafields: [
                    { name: 'Id', type: 'int' },
                    { name: 'TransactionTime', type: 'string' },
                    { name: 'Type', type: 'string' },
                    { name: 'Amount', type: 'float' },
                    { name: 'SignedAmount', type: 'float' },
                    { name: 'PowerBankId', type: 'int' },
                    { name: 'CustomerName', type: 'string' },
                    { name: 'CardInfo', type: 'string' },
                    { name: 'CardExpiry', type: 'string' },
                    { name: 'CardCountry', type: 'string' },
                    { name: 'UserId', type: 'string' },
                    { name: 'SessionId', type: 'string' }
                ],
                url: '@Url.Action("GetTransactionsByStation", "Actions")?stationId=' + stationId,
                async: true
            };

            var nestedAdapter = new $.jqx.dataAdapter(nestedSource);

            var timeRenderer = function(row, column, value) {
                if (!value) return '<div style="display: flex; align-items: center; height: 100%; padding: 0 8px; color: #9CA3AF;">-</div>';
                var date = new Date(value);
                if (isNaN(date.getTime()) || date.getFullYear() < 2000) return '<div style="display: flex; align-items: center; height: 100%; padding: 0 8px; color: #9CA3AF;">-</div>';
                var formatted = date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
                return '<div style="display: flex; align-items: center; height: 100%; padding: 0 8px;">' +
                    '<span style="font-size: 0.8rem; color: #6B7280;">' + formatted + '</span>' +
                    '</div>';
            };

            var typeRenderer = function(row, column, value) {
                var bgColor = '#6B7280';
                var label = value;
                if (value === 'Capture') {
                    bgColor = '#059669';
                    label = 'Payment';
                } else if (value === 'Refund') {
                    bgColor = '#DC2626';
                    label = 'Refund';
                } else if (value === 'Release') {
                    bgColor = '#F59E0B';
                    label = 'Released';
                }
                return '<div style="display: flex; align-items: center; height: 100%; padding: 0 8px;">' +
                    '<span style="background: ' + bgColor + '; color: white; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500;">' + label + '</span>' +
                    '</div>';
            };

            var amountRenderer = function(row, column, value, defaultHtml, columnproperties, rowdata) {
                var color = value >= 0 ? '#059669' : '#DC2626';
                var prefix = value >= 0 ? '+' : '';
                return '<div style="display: flex; align-items: center; justify-content: flex-end; height: 100%; padding: 0 12px;">' +
                    '<span style="font-weight: 600; color: ' + color + ';">' + prefix + value.toFixed(2) + ' EUR</span>' +
                    '</div>';
            };

            var payerInfoRenderer = function(row, column, value, defaultHtml, columnproperties, rowdata) {
                var card = rowdata.CardInfo || '';
                var expiry = rowdata.CardExpiry || '';
                var country = rowdata.CardCountry || '';
                var email = rowdata.UserId || '';

                var parts = [];
                if (card) parts.push('<span style="font-weight: 500;">' + card + '</span>');
                if (expiry) parts.push('<span style="color: #6B7280; font-size: 11px;">exp:' + expiry + '</span>');
                if (country) parts.push('<span style="color: #6B7280; font-size: 11px;">' + country + '</span>');
                if (email) parts.push('<span style="color: #6B7280; font-size: 11px;">' + email + '</span>');

                return '<div style="display: flex; align-items: center; gap: 6px; height: 100%; padding: 4px 8px; flex-wrap: wrap;">' +
                    parts.join(' ') +
                    '</div>';
            };

            $('#' + nestedGridId).jqxGrid({
                source: nestedAdapter,
                theme: 'material-purple',
                width: '100%',
                height: 200,
                sortable: true,
                rowsheight: 40,
                columnsresize: true,
                columns: [
                    { text: 'Time', datafield: 'TransactionTime', width: '18%', cellsrenderer: timeRenderer },
                    { text: 'Type', datafield: 'Type', width: '10%', cellsrenderer: typeRenderer },
                    { text: 'Amount', datafield: 'SignedAmount', width: '14%', cellsrenderer: amountRenderer, cellsalign: 'right' },
                    { text: 'PowerBank', datafield: 'PowerBankId', width: '10%' },
                    { text: 'Payer', datafield: 'CustomerName', width: '22%' },
                    { text: 'Payer Info', datafield: 'CardInfo', width: '26%', cellsrenderer: payerInfoRenderer }
                ]
            });

            nestedGrids.push(nestedGridId);
        }

        $(document).ready(function() {

            $("#jqxgrid").jqxGrid(
                {
                    width: '100%',
                    source: dataAdapter,
                    theme: 'material-purple',
                    sortable: true,
                    filterable: true,
                    rowsheight: 44,
                    enablebrowserselection: true,
                    selectionmode: 'multiplecellsadvanced',
                    height: 500,
                    columnsresize: true,
                    rowdetails: true,
                    rowdetailstemplate: {
                        rowdetails: "<div style='margin: 10px;'></div>",
                        rowdetailsheight: 220
                    },
                    initrowdetails: initRowDetails,
                    columns: [
                        { text: "Station", datafield: "StationName", width: "20%", cellsrenderer: cellsrenderer },
                        { text: "Month (EUR)", datafield: "MonthEarnings", width: "13%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                        { text: "Month Tx", datafield: "MonthTransactions", width: "10%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                        { text: "Year (EUR)", datafield: "YearEarnings", width: "13%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                        { text: "Year Tx", datafield: "YearTransactions", width: "10%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                        { text: "All Time (EUR)", datafield: "TotalEarnings", width: "14%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                        { text: "All Time Tx", datafield: "TotalTransactions", width: "10%", cellsrenderer: cellsrenderer, cellsalign: 'right' },
                     ]
                });
            refresh();
            $("#jqxWidget").css('display', 'block');
        });

    </script>
}

<style>
    /* Loading Overlay */
    .loading-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.9);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 100;
        border-radius: 12px;
    }

    .loading-spinner {
        width: 48px;
        height: 48px;
        border: 4px solid #E5E7EB;
        border-top-color: #7C3AED;
        border-radius: 50%;
        animation: spinner 0.8s linear infinite;
    }

    .loading-text {
        margin-top: 16px;
        color: #6B7280;
        font-size: 14px;
        font-weight: 500;
    }

    @@keyframes spinner {
        to { transform: rotate(360deg); }
    }

    .grid-container {
        position: relative;
    }
</style>

<div class="page-header">
    <h1><i class="fas fa-chart-line"></i> Financial Statistics</h1>
    <p class="page-subtitle">Revenue and transactions by station</p>
</div>

<div class="grid-container">
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-spinner"></div>
        <div class="loading-text">Loading financial data...</div>
    </div>
    <div id="jqxWidget"></div>
    <div id="jqxgrid"></div>
</div>

<div class="card-acharger mt-3" style="padding: 1rem 1.5rem;">
    <p style="margin: 0; color: var(--text-secondary); font-size: 0.875rem;">
        <i class="fas fa-info-circle me-1"></i>
        <strong>Note:</strong> Earnings = Captured payments - Refunds. "Tx" = number of successful transactions.
    </p>
</div>
