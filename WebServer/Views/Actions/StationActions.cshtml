<script src="~/jqwidgets/jqxbuttons.js"></script>
<script src="~/jqwidgets/jqxscrollbar.js"></script>
<script src="~/jqwidgets/jqxgrid.js"></script>
<script src="~/jqwidgets/jqxgrid.edit.js"></script>
<script src="~/jqwidgets/jqxgrid.columnsresize.js"></script>
<script src="~/jqwidgets/jqxgrid.filter.js"></script>
<script src="~/jqwidgets/jqxgrid.selection.js"></script>
<script src="~/jqwidgets/jqxgrid.sort.js"></script>
<script src="~/jqwidgets/jqxgrid.pager.js"></script>
<script src="~/jqwidgets/jqxgrid.aggregates.js"></script>
<script src="~/jqwidgets/jqxgrid.grouping.js"></script>
<script src="~/jqwidgets/jqxmenu.js"></script>
<script src="~/jqwidgets/jqxlistbox.js"></script>
<script src="~/jqwidgets/jqxdropdownlist.js"></script>
<script src="~/jqwidgets/jqxwindow.js"></script>
<script src="~/jqwidgets/jqxcore.js"></script>
<script src="~/jqwidgets/jqxdata.js"></script>

<meta name="keywords" content="jQuery Window, Window Widget, Window" />
<link rel="stylesheet" href="~/jqwidgets/styles/jqx.base.css" type="text/css" />
<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
<meta name="viewport" content="width=device-width, initial-scale=1 maximum-scale=1 minimum-scale=1" />

@{
    ViewData["Title"] = "Station Actions";
    var stationId = ViewBag.StationId;
    var stationName = ViewBag.StationName;
}

@section scripts
{
    <script type="text/javascript">

        var stationId = '@stationId';

        function cellsrenderer(row, column, value) {
            var jsonmod = source.localdata;
            var backcolor = "#FFFFFF";
            var text = value;

            // Payment actions - highlight in light blue
            if (jsonmod[row].ActionCode >= 0x4000 && jsonmod[row].ActionCode < 0x5000) {
                backcolor = "#E3F2FD";
            }

            var divstartstyle = "<div style='height: 32px; width: 100%; background: " + backcolor + ";'>";

            if (column === 'ActionTime') {
                function checkZero(data) {
                    if (data < 10) {
                        data = "0" + data;
                    }
                    return data;
                }
                var year = value.getFullYear();
                var month = checkZero(value.getMonth() + 1);
                var day = checkZero(value.getDate());
                var hour = checkZero(value.getHours());
                var min = checkZero(value.getMinutes());
                var sec = checkZero(value.getSeconds());

                var svalue = year + '/' + month + '/' + day + " " + hour + ":" + min + ":" + sec;

                return divstartstyle +
                    "<span style='margin-top: 5px; margin-left: 10px; position: absolute;'>" +
                    svalue +
                    "</span>" +
                    "</div>";
            } else if (column === 'PaymentAmount') {
                if (value > 0) {
                    return divstartstyle +
                        "<span style='margin-top: 5px; margin-left: 10px; position: absolute; font-weight: bold;'>" +
                        value.toFixed(2) + " EUR" +
                        "</span>" +
                        "</div>";
                }
                return divstartstyle + "</div>";
            } else if (column === 'PaymentInfo') {
                return divstartstyle +
                    "<span style='margin-top: 5px; margin-left: 10px; position: absolute; font-size: 0.9em;'>" +
                    (value || '') +
                    "</span>" +
                    "</div>";
            }

            return divstartstyle +
                "<span style='margin-top: 5px; margin-left: 10px; position: absolute;'>" +
                value +
                "</span>" +
                "</div>";
        }


        function refresh() {
            $.ajax({
                type: "GET",
                url: '@Url.Action("RefreshStation", "Actions")' + '?stationId=' + stationId,
                success: function(Data) {
                    source.localdata = Data;
                    if (!newdata) {
                        $("#jqxgrid").jqxGrid({ source: source });
                        newdata = true;
                    }
                    $("#jqxgrid").jqxGrid('updatebounddata', 'sort');
                }
            });
        }

        function goBack() {
            window.location.href = '@Url.Action("Devices", "Devices")';
        }

        var newdata = false;

        var source =
        {
            datatype: "json",
            sortcolumn: 'ActionTime',
            sortdirection: 'desc',
            datafields: [
                { name: 'ActionTime', type: 'date' },
                { name: 'ActionCode', type: 'numeric' },
                { name: 'UserId', type: 'string' },
                { name: 'ActionPowerBankId_Str', type: 'string' },
                { name: 'ActionPowerBankSlot', type: 'string' },
                { name: 'ActionText', type: 'string' },
                { name: 'PaymentAmount', type: 'float' },
                { name: 'PaymentInfo', type: 'string' }
            ]
        };

        var dataAdapter = new $.jqx.dataAdapter(source);

        $(document).ready(function() {

            $("#jqxgrid").jqxGrid(
                {
                    width: '100%',
                    source: dataAdapter,
                    sortable: true,
                    filterable: true,
                    rowsheight: 48,
                    enablebrowserselection: true,
                    selectionmode: 'multiplecellsadvanced',
                    height: 650,
                    columnsresize: true,
                    columns: [
                        { text: "Time", datafield: "ActionTime", width: "12%", cellsrenderer: cellsrenderer },
                        { text: "Action", datafield: "ActionText", width: "30%", cellsrenderer: cellsrenderer },
                        { text: "User", datafield: "UserId", width: "12%", cellsrenderer: cellsrenderer },
                        { text: "PowerBank", datafield: "ActionPowerBankId_Str", width: "8%", cellsrenderer: cellsrenderer },
                        { text: "Slot", datafield: "ActionPowerBankSlot", width: "5%", cellsrenderer: cellsrenderer },
                        { text: "Amount", datafield: "PaymentAmount", width: "8%", cellsrenderer: cellsrenderer },
                        { text: "Payment Info", datafield: "PaymentInfo", width: "25%", cellsrenderer: cellsrenderer },
                     ]
                });
            refresh();
            // Sort by ActionTime descending (newest first)
            $("#jqxgrid").jqxGrid('sortby', 'ActionTime', 'desc');
            $("#jqxWidget").css('display', 'block');
        });

    </script>
}

<style>
    .back-button {
        margin-bottom: 15px;
    }
    .station-header {
        margin-bottom: 20px;
    }
    .station-name {
        color: #2196F3;
    }
</style>

<div class="text-center station-header">
    <h2>Actions Log - Station <span class="station-name">@stationName</span></h2>
    <p>Last 30 days</p>
</div>

<div class="back-button">
    <button class="btn btn-secondary" onclick="goBack();">
        &larr; Back to Devices
    </button>
</div>

<div id="jqxWidget">
</div>

<div id="jqxgrid"></div>
