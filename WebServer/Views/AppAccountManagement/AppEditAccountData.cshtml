@model AppAccountDataEdit
@{
    ViewData["Title"] = "Edit User";
}

<div class="page-header">
    <h2><i class="fas fa-user-edit"></i> Edit User</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-header" style="background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%); color: white;">
                <h5 class="mb-0"><i class="fas fa-id-card me-2"></i>User Information</h5>
            </div>
            <div class="card-body">
                <form asp-action="AppEditAccountData" asp-controller="AppAccountManagement">
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-semibold">
                            <i class="fas fa-user me-1 text-muted"></i> Username
                        </label>
                        <input type="text" asp-for="UserName" class="form-control form-control-lg" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold">
                            <i class="fas fa-phone me-1 text-muted"></i> Phone Number
                        </label>
                        <input type="text" asp-for="PhoneNumber" class="form-control form-control-lg" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="AppAccounts" asp-controller="AppAccountManagement" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Back to Users
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
