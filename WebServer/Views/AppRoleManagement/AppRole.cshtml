@model IEnumerable<IdentityRole>

@{
    ViewBag.Title = "Role Management";
}

<div class="page-header">
    <h1><i class="fas fa-user-shield"></i> Role Management</h1>
    <p class="page-subtitle">Manage user roles and permissions</p>
</div>

<div class="card-acharger">
    <div class="card-header-acharger">
        <h5><i class="fas fa-users-cog me-2"></i>Available Roles</h5>
    </div>
    <div class="card-body-acharger p-0">
        @if (Model.Any())
        {
            <table class="table-acharger">
                <thead>
                    <tr>
                        <th style="width: 70%;">Role Name</th>
                        <th style="width: 30%; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="role-icon">
                                        <i class="fas fa-shield-alt"></i>
                                    </div>
                                    <div>
                                        <span class="fw-semibold">@role.Name</span>
                                        <br>
                                        <small class="text-muted">ID: @role.Id.Substring(0, 8)...</small>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <form method="get" asp-controller="AppRoleManagement" asp-action="EditRole" style="display: inline;">
                                    <input type="hidden" name="idRole" value="@role.Id" />
                                    <button type="submit" class="btn-acharger btn-primary-acharger" style="padding: 8px 20px;">
                                        <i class="fas fa-edit me-1"></i>Edit
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-user-shield"></i>
                <h5>No Roles Found</h5>
                <p>No roles have been created yet.</p>
            </div>
        }
    </div>
</div>

<style>
    .role-icon {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1rem;
    }

    .table-acharger {
        width: 100%;
        border-collapse: collapse;
    }

    .table-acharger thead {
        background: #F9FAFB;
    }

    .table-acharger th {
        padding: 14px 20px;
        text-align: left;
        font-weight: 600;
        color: #374151;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #E5E7EB;
    }

    .table-acharger td {
        padding: 16px 20px;
        border-bottom: 1px solid #E5E7EB;
        vertical-align: middle;
    }

    .table-acharger tbody tr:hover {
        background: #F9FAFB;
    }

    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #9CA3AF;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .empty-state h5 {
        color: #374151;
        margin-bottom: 8px;
    }
</style>
