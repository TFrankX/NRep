@model WebServer.Controllers.User.PayInfo
@{
    ViewData["Title"] = "Your Powerbank";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your Powerbank - A-Charger</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/acharger-theme.css" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <style>
        .status-card {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            border-radius: var(--border-radius);
            padding: 2rem;
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .status-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        .status-icon.taken {
            color: #10B981;
        }
        .status-icon.not-available {
            color: #F59E0B;
        }
        .user-id-badge {
            background: rgba(255,255,255,0.2);
            padding: 0.5rem 1rem;
            border-radius: 2rem;
            display: inline-block;
            margin-top: 0.5rem;
            font-size: 0.9rem;
        }
        .pb-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 1.5rem;
        }
        .pb-table th {
            background: var(--accent-light);
            color: var(--primary-dark);
            padding: 0.5rem 0.4rem;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .pb-table th:first-child {
            border-radius: var(--border-radius-sm) 0 0 0;
        }
        .pb-table th:last-child {
            border-radius: 0 var(--border-radius-sm) 0 0;
        }
        .pb-table td {
            padding: 0.6rem 0.4rem;
            border-bottom: 1px solid var(--border-color);
            text-align: center;
            font-size: 0.85rem;
        }
        .pb-table tr:last-child td {
            border-bottom: none;
        }
        .pb-table tr:last-child td:first-child {
            border-radius: 0 0 0 var(--border-radius-sm);
        }
        .pb-table tr:last-child td:last-child {
            border-radius: 0 0 var(--border-radius-sm) 0;
        }
        .pb-id {
            font-family: monospace;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .cost-value {
            font-weight: 600;
            color: var(--primary);
        }
        .total-row {
            background: var(--accent-light);
            font-weight: 600;
        }
        .total-row td {
            border-bottom: none !important;
        }
        .support-section {
            background: #F3F4F6;
            border-radius: var(--border-radius-sm);
            padding: 1rem;
            text-align: center;
            margin-top: 1.5rem;
        }
        .support-phone {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--primary);
        }
        .support-phone a {
            color: var(--primary);
            text-decoration: none;
        }
        .support-phone a:hover {
            text-decoration: underline;
        }
        .btn-take-more {
            width: 100%;
            margin-top: 1rem;
        }
        .no-powerbanks {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
        }
        .no-powerbanks i {
            font-size: 3rem;
            color: #F59E0B;
            margin-bottom: 1rem;
        }
        .returned-banner {
            background: linear-gradient(135deg, #10B981 0%, #059669 100%);
            color: white;
            border-radius: var(--border-radius);
            padding: 1.5rem;
            text-align: center;
            margin-bottom: 1.5rem;
            animation: slideIn 0.3s ease-out;
        }
        .returned-banner i {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }
        .returned-pb {
            background: rgba(255,255,255,0.2);
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            display: inline-block;
            margin: 0.25rem;
            font-size: 0.85rem;
        }
        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .pb-returned {
            background: #ECFDF5 !important;
        }
        .pb-returned td {
            color: #059669 !important;
            text-decoration: line-through;
        }
        .start-time {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }
        .duration {
            font-weight: 500;
        }
    </style>
</head>
<body class="login-page">
    <div class="login-card fade-in" style="max-width: 450px;">
        <div class="login-logo">
            <h1>
                <span class="logo-icon">
                    <i class="fas fa-bolt"></i>
                </span>
                A-Charger
            </h1>
        </div>

        <!-- Returned powerbanks banner (hidden by default) -->
        <div id="returnedBanner" class="returned-banner" style="display: none;">
            <i class="fas fa-check-circle"></i>
            <h3 style="margin: 0;">Powerbank Returned!</h3>
            <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Thank you for using A-Charger</p>
            <div id="returnedList" style="margin-top: 0.5rem;"></div>
        </div>

        @if (Model.Taken == 1)
        {
            <!-- Powerbank taken successfully -->
            <div id="statusCard" class="status-card">
                <div class="status-icon taken">
                    <i class="fas fa-battery-full"></i>
                </div>
                <h2 style="margin: 0; font-size: 1.5rem;">Powerbank Active</h2>
                <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Enjoy your charge!</p>
                @if (!string.IsNullOrEmpty(Model.UserId))
                {
                    <div class="user-id-badge">
                        <i class="fas fa-user me-1"></i> @Model.UserId
                    </div>
                }
            </div>

            @if (Model.PowerBanks != null && Model.PowerBanks.Count > 0)
            {
                <!-- Multiple powerbanks table -->
                <div id="pbTableContainer" style="background: white; border-radius: var(--border-radius-sm); overflow: hidden; box-shadow: var(--shadow-sm);">
                    <table class="pb-table" id="pbTable">
                        <thead>
                            <tr>
                                <th>P-Bank</th>
                                <th>Taken</th>
                                <th>Time</th>
                                <th>Cost</th>
                            </tr>
                        </thead>
                        <tbody id="pbTableBody">
                            @foreach (var pb in Model.PowerBanks)
                            {
                                var displayName = !string.IsNullOrEmpty(pb.PowerBankName) ? pb.PowerBankName : pb.PowerBankId;
                                <tr data-pb-id="@pb.PowerBankId">
                                    <td class="pb-id" title="@pb.PowerBankId">@displayName</td>
                                    <td class="start-time">@pb.StartTime</td>
                                    <td class="duration">@pb.Time</td>
                                    <td class="cost-value">@pb.Cost.ToString("F2")€</td>
                                </tr>
                            }
                            @if (Model.PowerBanks.Count > 1)
                            {
                                <tr class="total-row" id="totalRow">
                                    <td colspan="3" style="text-align: right;">Total:</td>
                                    <td class="cost-value" id="totalCost">@Model.PowerBanks.Sum(p => p.Cost).ToString("F2") &euro;</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <!-- Single powerbank (legacy) -->
                <div style="background: white; border-radius: var(--border-radius-sm); padding: 1.5rem; box-shadow: var(--shadow-sm);">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span style="color: var(--text-secondary);">Time</span>
                        <span style="font-weight: 600;">@Model.Time</span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-secondary);">Cost</span>
                        <span class="cost-value">@Model.Cost.ToString("F2") &euro;</span>
                    </div>
                </div>
            }

            @if (Model.CanTakeMore)
            {
                <button type="button" id="takeMoreBtn" class="btn-acharger btn-primary-acharger btn-take-more" onclick="takeMorePowerbank()">
                    <i class="fas fa-plus me-2"></i>
                    Take Another Powerbank
                </button>
            }
        }
        else
        {
            <!-- No powerbank available -->
            <div class="no-powerbanks">
                <i class="fas fa-battery-empty"></i>
                <h3 style="margin: 0 0 0.5rem 0;">No Powerbanks Available</h3>
                <p style="margin: 0; color: var(--text-secondary);">
                    Please try again later or visit another station.
                </p>
            </div>
        }

        <!-- Support section -->
        <div class="support-section">
            <p style="margin: 0 0 0.5rem 0; color: var(--text-secondary); font-size: 0.9rem;">
                <i class="fas fa-headset me-1"></i> Need help?
            </p>
            <div class="support-phone">
                <a href="tel:@Model.SupportPhone.Replace(" ", "")">
                    <i class="fas fa-phone me-1"></i> @Model.SupportPhone
                </a>
            </div>
            @if (!string.IsNullOrEmpty(Model.SupportEmail))
            {
                <div style="margin-top: 0.5rem;">
                    <a href="mailto:@Model.SupportEmail" style="color: var(--text-secondary); font-size: 0.9rem;">
                        <i class="fas fa-envelope me-1"></i> @Model.SupportEmail
                    </a>
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        // Track known powerbank IDs and names
        var knownPowerBanks = [@Html.Raw(string.Join(",", Model.PowerBanks?.Select(p => $"\"{p.PowerBankId}\"") ?? new string[0]))];
        var powerBankNames = {
            @Html.Raw(string.Join(",\n            ", Model.PowerBanks?.Select(p => $"\"{p.PowerBankId}\": \"{(!string.IsNullOrEmpty(p.PowerBankName) ? p.PowerBankName : p.PowerBankId)}\"") ?? new string[0]))
        };
        var returnedPowerBanks = [];
        var pollingInterval = null;
        var initialCount = @(Model.PowerBanks?.Count ?? 0);
        var confirmedActive = false; // Wait for first successful poll before tracking returns
        var pollCount = 0;

        function takeMorePowerbank() {
            const btn = document.getElementById('takeMoreBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Dispensing...';

            fetch('/User/TakeMorePowerbank', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    stationId: '@Model.StationId'
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Failed to dispense powerbank');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-plus me-2"></i>Take Another Powerbank';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Connection error. Please try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-plus me-2"></i>Take Another Powerbank';
            });
        }

        function checkPowerBankStatus() {
            pollCount++;

            fetch('/User/CheckPowerBankStatus')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        var activePbIds = data.powerBanks.map(pb => pb.powerBankId);

                        // First successful poll with powerbanks confirms they're active
                        if (!confirmedActive && data.count > 0) {
                            confirmedActive = true;
                            knownPowerBanks = activePbIds.slice();
                        }

                        // Track returns after confirmed active
                        if (confirmedActive) {
                            knownPowerBanks.forEach(function(pbId) {
                                if (!activePbIds.includes(pbId) && !returnedPowerBanks.includes(pbId)) {
                                    returnedPowerBanks.push(pbId);
                                    markAsReturned(pbId);
                                }
                            });
                        }

                        // Update time and cost
                        data.powerBanks.forEach(function(pb) {
                            var row = document.querySelector('tr[data-pb-id="' + pb.powerBankId + '"]');
                            if (row && !returnedPowerBanks.includes(pb.powerBankId)) {
                                var cells = row.querySelectorAll('td');
                                if (cells.length >= 4) {
                                    cells[2].textContent = pb.time;
                                    cells[3].textContent = pb.cost.toFixed(2) + '€';
                                }
                            }
                        });

                        // Update total cost
                        var totalEl = document.getElementById('totalCost');
                        if (totalEl && data.totalCost !== undefined) {
                            totalEl.textContent = data.totalCost.toFixed(2) + '€';
                        }

                        // Show "all returned" message
                        if (confirmedActive && data.count === 0 && returnedPowerBanks.length > 0) {
                            showAllReturned();
                        }
                    }
                })
                .catch(function() {});
        }

        function markAsReturned(pbId) {
            var row = document.querySelector('tr[data-pb-id="' + pbId + '"]');
            if (row) {
                row.classList.add('pb-returned');
            }

            // Show returned banner with powerbank name
            var displayName = powerBankNames[pbId] || pbId;
            var banner = document.getElementById('returnedBanner');
            var list = document.getElementById('returnedList');
            banner.style.display = 'block';
            list.innerHTML += '<span class="returned-pb">' + displayName + '</span>';
        }

        function showAllReturned() {
            // Hide status card and table
            var statusCard = document.getElementById('statusCard');
            var tableContainer = document.getElementById('pbTableContainer');
            var takeMoreBtn = document.getElementById('takeMoreBtn');

            if (statusCard) statusCard.style.display = 'none';
            if (tableContainer) tableContainer.style.display = 'none';
            if (takeMoreBtn) takeMoreBtn.style.display = 'none';

            // Update banner
            var banner = document.getElementById('returnedBanner');
            banner.innerHTML = '<i class="fas fa-check-circle"></i>' +
                '<h3 style="margin: 0;">All Powerbanks Returned!</h3>' +
                '<p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Thank you for using A-Charger</p>';

            // Stop polling
            if (pollingInterval) {
                clearInterval(pollingInterval);
            }
        }

        // Start polling if there are active powerbanks
        if (initialCount > 0) {
            setTimeout(checkPowerBankStatus, 2000);
            pollingInterval = setInterval(checkPowerBankStatus, 5000);
        }
    </script>
</body>
</html>
